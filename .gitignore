# Whitelist: `*` + `.*` ignore everything by default — nothing is tracked unless a `!…` line allows it.
# Workflow: CONTRIBUTING.md

*
.*

# Needed so negated paths can match inside directories
!**/

# --- Dotfiles at repo root ---
!.gitattributes
!.gitignore
!.ruby-gemset
!.ruby-version

# --- Root project files ---
!Gemfile
!Gemfile.lock
!LICENSE
!Procfile.dev
!README.md
!Rakefile
!SPECIFICATIONS.md
!CODE_OF_CONDUCT.md
!CONTRIBUTING.md
!CHANGELOG.md
!config.ru
!package.json
!VERSION

# --- Docker ---
!Dockerfile
!.dockerignore
!Makefile
!docker-compose.yml

# --- GitHub Actions ---
!.github/
!.github/**/*

# --- Rails trees (entire contents) ---
!/app/
!/app/**/*

!/bin/
!/bin/**/*

!/config/
!/config/**/*

!/db/
!/db/**/*

!/lib/
!/lib/**/*

!/log/
/log/*
!/log/.keep

!/public/
!/public/**/*

!/test/
!/test/**/*

!/tmp/
/tmp/*
!/tmp/.keep

# --- Narrow re-ignore inside trees above (must stay after the !/…/** rules) ---
**/.DS_Store
/app/assets/builds/*
!/app/assets/builds/.keep
/db/*.sqlite3
/db/*.sqlite3-journal
/config/master.key

# Opt-in template (otherwise hidden files stay ignored via `.*`)
!.env.example
