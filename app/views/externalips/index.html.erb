<%= render "/common/header" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-0 pb-10">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-gray-900"><%= t("external_ips") %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= t("admin_crud_list_subtitle", count: @externalips.count) %></p>
    </div>
    <%= link_to t("add_external_ip"), new_externalip_path, class: "inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
  </div>

  <%= render "common/admin_flash" %>

  <% if @externalips.present? %>
    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gradient-to-b from-gray-50 to-gray-100/80">
            <tr>
              <th scope="col" class="w-14 px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600">#</th>
              <th scope="col" class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("ip") %></th>
              <th scope="col" class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("hostname") %></th>
              <th scope="col" class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("short_hostname") %></th>
              <th scope="col" class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("notes") %></th>
              <th scope="col" class="px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("include_in_etc_hosts") %></th>
              <th scope="col" class="relative px-5 py-3.5 text-right text-xs font-semibold uppercase tracking-wider text-gray-600">
                <span class="sr-only"><%= t("edit") %></span>
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% @externalips.each_with_index do |externalip, idx| %>
              <tr class="transition-colors hover:bg-gray-50/90">
                <td class="whitespace-nowrap px-5 py-4 text-center text-sm font-mono text-gray-500"><%= idx + 1 %></td>
                <td class="whitespace-nowrap px-5 py-4 text-sm font-mono font-medium text-gray-900"><%= externalip.address %></td>
                <td class="whitespace-nowrap px-5 py-4 text-sm text-gray-600"><%= externalip.hostname %></td>
                <td class="whitespace-nowrap px-5 py-4 text-sm text-gray-600"><%= externalip.short_hostname %></td>
                <td class="max-w-xs px-5 py-4 text-sm text-gray-600 truncate" title="<%= externalip.notes %>"><%= externalip.notes %></td>
                <td class="whitespace-nowrap px-5 py-4 text-center text-sm text-gray-600"><%= get_icon(externalip.include_in_etc_hosts) %></td>
                <td class="whitespace-nowrap px-5 py-4 text-right text-sm">
                  <%= link_to t("edit"), edit_externalip_path(externalip), class: "font-medium text-indigo-600 hover:text-indigo-500" %>
                  <span class="mx-2 text-gray-300" aria-hidden="true">|</span>
                  <%= link_to t("destroy"), externalip, data: { turbo_method: :delete, turbo_confirm: t("are_you_sure") }, class: "font-medium text-red-600 hover:text-red-500" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="rounded-lg border border-amber-100 bg-amber-50 px-4 py-3 text-sm text-amber-900 shadow-sm" role="status">
      <%= t("not_found_externalips") %>
    </div>
  <% end %>
</div>
