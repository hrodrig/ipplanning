<%= form_with(model: externalip, local: true, class: "space-y-6") do |form| %>
  <% if externalip.errors.any? %>
    <div class="rounded-md bg-red-50 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(externalip.errors.count, "error") %> <%= t('prohibited_this_information_from_being_saved') %>:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% externalip.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :address, t('externalip_address'), class: form_label_class %>
    <div class="mt-2">
      <%= form.text_field :address, id: :externalip_address, class: form_control_class, placeholder: t('placeholder_externalip_address') %>
    </div>
    <p class="mt-2 text-sm text-gray-500"><%= t('placeholder_externalip_address_help') %></p>
  </div>

  <div>
    <%= form.label :hostname, t('externalip_hostname'), class: form_label_class %>
    <div class="mt-2">
      <%= form.text_field :hostname, id: :externalip_hostname, class: form_control_class, placeholder: t('placeholder_externalip_hostname') %>
    </div>
    <p class="mt-2 text-sm text-gray-500"><%= t('placeholder_externalip_hostname_help') %></p>
  </div>

  <div>
    <%= form.label :short_hostname, t('externalip_short_hostname'), class: form_label_class %>
    <div class="mt-2">
      <%= form.text_field :short_hostname, id: :externalip_short_hostname, class: form_control_class, placeholder: t('placeholder_externalip_short_hostname') %>
    </div>
    <p class="mt-2 text-sm text-gray-500"><%= t('placeholder_externalip_short_hostname_help') %></p>
  </div>

  <div class="relative flex items-start">
    <div class="flex h-6 items-center">
      <%= form.check_box :include_in_etc_hosts, id: :externalip_include_in_etc_hosts, class: form_checkbox_class %>
    </div>
    <div class="ml-3 text-sm leading-6">
      <%= form.label :include_in_etc_hosts, t('include_in_etc_hosts') + ' ?', class: "font-medium text-gray-900" %>
      <p class="text-gray-500"><%= t('placeholder_externalip_include_in_etc_hosts_help') %></p>
    </div>
  </div>

  <div>
    <%= form.label :notes, t('externalip_notes'), class: form_label_class %>
    <div class="mt-2">
      <%= form.text_area :notes, id: :externalip_notes, rows: 3, class: form_control_class, placeholder: t('placeholder_externalip_notes') %>
    </div>
    <p class="mt-2 text-sm text-gray-500"><%= t('placeholder_externalip_notes_help') %></p>
  </div>

  <div class="flex items-center justify-end mt-4">
    <%= form.submit t('ok'), class: 'inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600' %>
  </div>
<% end %>
