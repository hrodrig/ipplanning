<%= render layout: "common/admin_resource_form", locals: {
  heading: "#{t('external_ips')}: #{@externalip.address}",
  index_path: externalips_path,
  index_label: t("external_ips"),
  current_label: @externalip.address,
  back_path: externalips_path,
  primary_action_path: edit_externalip_path(@externalip),
  width_class: "max-w-6xl",
  form_card: false
} do %>
  <div class="mb-10 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4">
      <h2 class="text-base font-semibold text-gray-900"><%= t("details") %></h2>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("externalip_address") %></dt>
        <dd class="mt-1 text-sm font-mono text-gray-900 sm:col-span-2 sm:mt-0"><%= @externalip.address %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("externalip_hostname") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @externalip.hostname %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("externalip_short_hostname") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @externalip.short_hostname %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("include_in_etc_hosts") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= get_icon @externalip.include_in_etc_hosts %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("externalip_notes") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 whitespace-pre-wrap"><%= @externalip.notes %></dd>
      </div>
    </dl>
  </div>

  <div class="mt-10">
    <%= link_to t("add_external_ip"), new_externalip_path, class: "inline-flex items-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-indigo-700 shadow-sm ring-1 ring-inset ring-indigo-200 hover:bg-indigo-50" %>
  </div>
<% end %>
