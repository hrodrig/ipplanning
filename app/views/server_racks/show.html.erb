<%= render layout: "common/admin_resource_form", locals: {
  heading: "#{t('server_rack')}: #{@server_rack.name}",
  index_path: server_racks_path,
  index_label: t("server_racks"),
  current_label: @server_rack.name,
  back_path: server_racks_path,
  primary_action_path: edit_server_rack_path(@server_rack),
  width_class: "max-w-6xl",
  form_card: false
} do %>
  <div class="mb-10 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4">
      <h2 class="text-base font-semibold text-gray-900"><%= t("details") %></h2>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("server_rack_location") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
          <%= link_to @server_rack.location.name, @server_rack.location, class: "text-indigo-600 hover:text-indigo-500" %>
        </dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("server_rack_name") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @server_rack.name %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("server_rack_u_height") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @server_rack.u_height.presence || "—" %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("server_rack_notes") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 whitespace-pre-wrap"><%= @server_rack.notes %></dd>
      </div>
    </dl>
  </div>

  <%= render "server_racks/u_diagram", server_rack: @server_rack, highlight_host: @rack_diagram_highlight_host, highlight_network_switch: @rack_diagram_highlight_network_switch %>

  <div class="mb-10 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4">
      <h2 class="text-base font-semibold text-gray-900"><%= t("server_rack_hosts") %></h2>
    </div>
    <div class="p-5">
      <% rack_hosts = @server_rack.hosts.order(:name).to_a %>
      <% if rack_hosts.any? %>
        <ul class="divide-y divide-gray-100">
          <% rack_hosts.each do |h| %>
            <li class="flex flex-wrap items-center justify-between gap-2 py-3 text-sm">
              <%= link_to h.name, h, class: "font-medium text-indigo-600 hover:text-indigo-500" %>
              <span class="flex flex-wrap items-center gap-2 text-gray-600">
                <% if h.rack_mount? && (label = host_rack_u_range_label(h)) %>
                  <%= link_to label, server_rack_path(@server_rack, highlight_host_id: h.id), class: "font-mono text-xs font-semibold text-amber-800 hover:text-amber-950 hover:underline", title: t("server_rack_u_diagram_highlight_link_title") %>
                <% end %>
                <span>
                  <%= h.rack_units %> U
                  <% if h.rack_position_start.present? %>
                    <span class="text-gray-500">· <%= t("host_rack_position_start") %> <%= h.rack_position_start %></span>
                  <% end %>
                </span>
              </span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-gray-500"><%= t("server_rack_no_hosts") %></p>
      <% end %>
    </div>
  </div>

  <div class="mb-10 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4 flex flex-wrap items-center justify-between gap-3">
      <h2 class="text-base font-semibold text-gray-900"><%= t("server_rack_network_switches") %></h2>
      <%= link_to t("add_network_switch"), new_network_switch_path(server_rack_id: @server_rack.id), class: "inline-flex items-center rounded-lg bg-white px-3 py-1.5 text-sm font-semibold text-indigo-700 shadow-sm ring-1 ring-inset ring-indigo-200 hover:bg-indigo-50" %>
    </div>
    <div class="p-5">
      <% rack_switches = @server_rack.network_switches.sort_by(&:name) %>
      <% if rack_switches.any? %>
        <ul class="divide-y divide-gray-100">
          <% rack_switches.each do |sw| %>
            <li class="flex flex-wrap items-center justify-between gap-2 py-3 text-sm">
              <%= link_to sw.name, sw, class: "font-medium text-indigo-600 hover:text-indigo-500" %>
              <span class="flex flex-wrap items-center gap-2 text-gray-600">
                <% if (label = network_switch_rack_u_range_label(sw)) %>
                  <%= link_to label, server_rack_path(@server_rack, highlight_network_switch_id: sw.id), class: "font-mono text-xs font-semibold text-amber-800 hover:text-amber-950 hover:underline", title: t("server_rack_u_diagram_highlight_network_switch_link_title") %>
                <% end %>
                <span>
                  <%= sw.rack_units %> U
                  <% if sw.rack_position_start.present? %>
                    <span class="text-gray-500">· <%= t("network_switch_rack_position_start") %> <%= sw.rack_position_start %></span>
                  <% end %>
                </span>
                <span class="text-gray-500"><%= sw.switch_ports.size %> <%= t("switch_ports") %></span>
              </span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-gray-500"><%= t("server_rack_no_network_switches") %></p>
      <% end %>
    </div>
  </div>

  <h2 class="mb-4 text-lg font-bold tracking-tight text-gray-900"><%= t("server_rack_photos") %></h2>
  <% if @server_rack.photos.attached? %>
    <div class="flex flex-wrap gap-4">
      <% @server_rack.photos.each do |file| %>
        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <% if file.representable? %>
            <%= image_tag file, class: "max-h-64 max-w-full object-contain" %>
          <% else %>
            <%= link_to file.filename.to_s, url_for(file), class: "block p-4 text-sm text-indigo-600 hover:text-indigo-500" %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-600 shadow-sm" role="status">
      <%= t("not_found_server_rack_photos") %>
    </div>
  <% end %>

  <div class="mt-10 flex flex-wrap gap-3">
    <%= link_to t("add_server_rack"), new_server_rack_path, class: "inline-flex items-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-indigo-700 shadow-sm ring-1 ring-inset ring-indigo-200 hover:bg-indigo-50" %>
  </div>
<% end %>
