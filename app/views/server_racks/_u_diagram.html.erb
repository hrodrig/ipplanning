<%# locals: server_rack (required), highlight_host (optional Host), highlight_network_switch (optional NetworkSwitch) %>
<% rows = rack_u_diagram_rows(server_rack, highlight_host: local_assigns[:highlight_host], highlight_network_switch: local_assigns[:highlight_network_switch]) %>
<% missing_hosts = rack_hosts_missing_placement(server_rack) %>
<% missing_switches = rack_network_switches_missing_placement(server_rack) %>
<% show_focus_legend = local_assigns[:highlight_host].present? || local_assigns[:highlight_network_switch].present? %>
<div class="mb-10 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
  <div class="border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4">
    <h2 class="text-base font-semibold text-gray-900"><%= t("server_rack_u_diagram_title") %></h2>
    <p class="mt-1 text-xs text-gray-600"><%= t("server_rack_u_diagram_hint") %></p>
    <div class="mt-3 flex flex-wrap gap-4 text-xs text-gray-600">
      <span class="inline-flex items-center gap-1.5">
        <span class="h-3 w-6 rounded border border-gray-200 bg-gray-100" aria-hidden="true"></span>
        <%= t("server_rack_u_diagram_legend_free") %>
      </span>
      <span class="inline-flex items-center gap-1.5">
        <span class="h-3 w-6 rounded border border-emerald-600/40 bg-emerald-200" aria-hidden="true"></span>
        <%= t("server_rack_u_diagram_legend_host") %>
      </span>
      <span class="inline-flex items-center gap-1.5">
        <span class="h-3 w-6 rounded border border-indigo-600/40 bg-indigo-200" aria-hidden="true"></span>
        <%= t("server_rack_u_diagram_legend_network_switch") %>
      </span>
      <% if show_focus_legend %>
        <span class="inline-flex items-center gap-1.5">
          <span class="h-3 w-6 rounded border-2 border-amber-600 bg-amber-300 shadow-sm ring-2 ring-amber-400/80" aria-hidden="true"></span>
          <%= t("server_rack_u_diagram_legend_focus") %>
        </span>
      <% end %>
    </div>
  </div>
  <div class="p-5">
    <% if missing_hosts.any? %>
      <div class="mb-4 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-950" role="status">
        <%= t("server_rack_u_diagram_unplaced_warning", count: missing_hosts.size, names: missing_hosts.map(&:name).join(", ")) %>
      </div>
    <% end %>
    <% if missing_switches.any? %>
      <div class="mb-4 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-950" role="status">
        <%= t("server_rack_u_diagram_unplaced_switch_warning", count: missing_switches.size, names: missing_switches.map(&:name).join(", ")) %>
      </div>
    <% end %>
    <div class="mx-auto max-w-xl">
      <div class="flex justify-center gap-2 border-b border-gray-300 pb-1 text-[10px] font-semibold uppercase tracking-wider text-gray-500">
        <span class="w-8 text-right"><%= t("server_rack_u_diagram_column_u") %></span>
        <span class="min-w-0 flex-1 text-center"><%= t("server_rack_u_diagram_column_front") %></span>
      </div>
      <div class="rack-u-diagram-scroll max-h-[min(70vh,520px)] overflow-y-auto overflow-x-hidden rounded-b-lg border border-t-0 border-gray-300 bg-gradient-to-r from-gray-200/80 via-gray-100 to-gray-200/80 px-1.5 py-1 shadow-inner">
        <% rows.each do |row| %>
          <% u = row[:u] %>
          <% hosts_here = row[:hosts] %>
          <% switches_here = row[:switches] %>
          <% focused = row[:focused] %>
          <% occupied = hosts_here.any? || switches_here.any? %>
          <% titles = (hosts_here.map(&:name) + switches_here.map(&:name)).join(", ") %>
          <div class="grid grid-cols-[2rem_1fr] items-stretch gap-1.5 py-px">
            <div class="flex items-center justify-end pr-0.5 text-[10px] font-mono font-medium tabular-nums text-gray-500">
              <%= u %>
            </div>
            <% if focused %>
              <div
                class="flex min-h-[1.125rem] flex-col gap-0.5 rounded border-2 border-amber-600 bg-amber-300 px-1.5 py-0.5 text-[10px] font-semibold leading-tight text-amber-950 shadow-md ring-2 ring-amber-400/90"
                title="<%= titles %>"
              >
                <% if hosts_here.any? %>
                  <div class="flex min-h-[1.125rem] items-center">
                    <%= safe_join(hosts_here.map { |h| link_to(h.name, h, class: "truncate underline decoration-amber-800/60 hover:text-amber-900") }, ", ") %>
                  </div>
                <% end %>
                <% if switches_here.any? %>
                  <div class="flex min-h-[1.125rem] items-center">
                    <%= safe_join(switches_here.map { |sw| link_to(sw.name, sw, class: "truncate underline decoration-amber-800/60 hover:text-amber-900") }, ", ") %>
                  </div>
                <% end %>
              </div>
            <% elsif occupied %>
              <div class="flex min-h-[1.125rem] flex-col gap-0.5" title="<%= titles %>">
                <% if hosts_here.any? %>
                  <div class="flex min-h-[1.125rem] items-center rounded border border-emerald-600/50 bg-emerald-200/90 px-1.5 text-[10px] font-medium leading-tight text-emerald-950">
                    <%= safe_join(hosts_here.map { |h| link_to(h.name, h, class: "truncate text-emerald-950 hover:underline") }, ", ") %>
                  </div>
                <% end %>
                <% if switches_here.any? %>
                  <div class="flex min-h-[1.125rem] items-center rounded border border-indigo-600/50 bg-indigo-200/90 px-1.5 text-[10px] font-medium leading-tight text-indigo-950">
                    <%= safe_join(switches_here.map { |sw| link_to(sw.name, sw, class: "truncate text-indigo-950 hover:underline") }, ", ") %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="min-h-[1.125rem] rounded border border-gray-300/60 bg-gray-100/90" aria-hidden="true"></div>
            <% end %>
          </div>
        <% end %>
      </div>
      <p class="mt-2 text-center text-[10px] text-gray-500"><%= t("server_rack_u_diagram_footer_u1") %></p>
    </div>
  </div>
</div>
