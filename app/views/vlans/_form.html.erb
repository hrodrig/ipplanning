<%= form_with(model: vlan, local: true, html: { class: "space-y-6" }) do |form| %>
  <% if vlan.errors.any? %>
    <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-6 rounded shadow-sm" role="alert">
      <h2 class="font-bold mb-2"><%= pluralize(vlan.errors.count, "error") %> <%= t('prohibited_this_information_from_being_saved') %>:</h2>
      <ul class="list-disc list-inside text-sm">
      <% vlan.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-start">
    <%= form.label :number, t('id') + ' :', class: "md:col-span-2 block text-gray-700 text-sm font-bold pt-2 uppercase tracking-wide" %>
    <div class="md:col-span-10">
      <%= form.number_field :number, id: :vlan_number, class: form_control_class, placeholder: t('placeholder_vlan_id') %>
      <p class="text-gray-500 text-xs italic mt-1"><%= t('placeholder_vlan_id_help') %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-start">
    <%= form.label :name, t('name') + ' :', class: "md:col-span-2 block text-gray-700 text-sm font-bold pt-2 uppercase tracking-wide" %>
    <div class="md:col-span-10">
      <%= form.text_field :name, id: :vlan_name, class: form_control_class, placeholder: t('placeholder_vlan_name') %>
      <p class="text-gray-500 text-xs italic mt-1"><%= t('placeholder_vlan_name_help') %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-start">
    <%= form.label :descriptor, t('descriptor') + ' :', class: "md:col-span-2 block text-gray-700 text-sm font-bold pt-2 uppercase tracking-wide" %>
    <div class="md:col-span-10">
      <%= form.text_field :descriptor, id: :vlan_descriptor, class: form_control_class, placeholder: t('placeholder_vlan_descriptor') %>
      <p class="text-gray-500 text-xs italic mt-1"><%= t('placeholder_vlan_descriptor_help') %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-start">
    <%= form.label :network, t('network') + ' :', class: "md:col-span-2 block text-gray-700 text-sm font-bold pt-2 uppercase tracking-wide" %>
    <div class="md:col-span-10">
      <%= form.text_field :network, id: :vlan_network, class: form_control_class, placeholder: t('placeholder_vlan_network') %>
      <p class="text-gray-500 text-xs italic mt-1"><%= t('placeholder_vlan_network_help') %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-start">
    <%= form.label :netmask, t('netmask') + ' :', class: "md:col-span-2 block text-gray-700 text-sm font-bold pt-2 uppercase tracking-wide" %>
    <div class="md:col-span-10">
      <%= form.text_field :netmask, id: :vlan_netmask, class: form_control_class, placeholder: t('placeholder_vlan_netmask') %>
      <p class="text-gray-500 text-xs italic mt-1"><%= t('placeholder_vlan_netmask_help') %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-start">
    <%= form.label :gateway, t('gateway') + ' :', class: "md:col-span-2 block text-gray-700 text-sm font-bold pt-2 uppercase tracking-wide" %>
    <div class="md:col-span-10">
      <%= form.text_field :gateway, id: :vlan_gateway, class: form_control_class, placeholder: t('placeholder_vlan_default_gateway') %>
      <p class="text-gray-500 text-xs italic mt-1"><%= t('placeholder_vlan_default_gateway_help') %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
    <%= form.label :include_in_etc_hosts, t('include_in_etc_hosts') + ' ?', class: "md:col-span-2 block text-gray-700 text-sm font-bold uppercase tracking-wide" %>
    <div class="md:col-span-10 flex items-center">
      <%= form.check_box :include_in_etc_hosts, id: :vlan_include_in_etc_hosts, class: form_checkbox_class %>
      <p class="ml-3 text-gray-500 text-xs italic"><%= t('placeholder_vlan_include_in_etc_hosts_help') %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-start">
    <%= form.label :notes, t('notes') + ' :', class: "md:col-span-2 block text-gray-700 text-sm font-bold pt-2 uppercase tracking-wide" %>
    <div class="md:col-span-10">
      <%= form.text_area :notes, id: :vlan_notes, rows: 4, class: form_control_class, placeholder: t('placeholder_vlan_notes') %>
      <p class="text-gray-500 text-xs italic mt-1"><%= t('placeholder_vlan_notes_help') %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-4 pt-4">
    <div class="md:col-span-2"></div>
    <div class="md:col-span-10">
      <%= form.submit t("ok"), class: "w-full cursor-pointer rounded-lg bg-indigo-600 px-6 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 md:w-auto" %>
    </div>
  </div>

<% end %>
