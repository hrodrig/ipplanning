<%= render layout: "common/admin_resource_form", locals: {
  heading: "#{t('vlan')} #{@vlan.number}",
  index_path: vlans_path,
  index_label: t("vlans"),
  current_label: @vlan.name,
  back_path: vlans_path,
  primary_action_path: edit_vlan_path(@vlan),
  width_class: "max-w-7xl",
  form_card: false
} do %>
  <p class="mb-6 text-sm">
    <%= link_to t("show_all"), vlans_path, class: "font-medium text-indigo-600 hover:text-indigo-500" %>
  </p>

  <div class="mb-8">
    <%= render "menu_vlans" %>
  </div>

  <div class="mb-8 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4">
      <h2 class="text-base font-semibold text-gray-900"><%= t("details") %></h2>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("vlan_id") %> / <%= t("vlan_name") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @vlan.number.to_s %> / <%= @vlan.name %></dd>
      </div>
      <% if @vlan.descriptor.present? %>
        <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-700"><%= t("vlan_descriptor") %></dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @vlan.descriptor %></dd>
        </div>
      <% end %>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("network") %> / <%= t("netmask") %> / <%= t("gateway") %></dt>
        <dd class="mt-1 text-sm font-mono text-gray-900 sm:col-span-2 sm:mt-0"><%= @vlan.network %> / <%= @vlan.netmask.to_s %> / <%= @vlan.gateway %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("ips_assigned") %> / <%= t("ips_used") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @vlan.ips.count.to_s %> / <%= @vlan.used_ips %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("include_in_etc_hosts") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= get_icon @vlan.include_in_etc_hosts %></dd>
      </div>
      <% if @vlan.notes.present? %>
        <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-700"><%= t("notes") %></dt>
          <dd class="mt-1 text-sm leading-relaxed text-gray-900 sm:col-span-2 sm:mt-0"><%= @vlan.notes.html_safe %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <div class="mb-4 flex flex-wrap items-center justify-end gap-2">
    <%= link_to t("add_ip_to_vlan"), new_ip_vlan_path(@vlan), class: "inline-flex items-center rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
    <% if @vlan.ips.empty? %>
      <%= link_to t("generate"), generate_network_path(@vlan), class: "inline-flex items-center rounded-lg bg-white px-3 py-1.5 text-sm font-semibold text-indigo-700 shadow-sm ring-1 ring-inset ring-indigo-200 hover:bg-indigo-50" %>
    <% end %>
  </div>

  <% if @vlan.ips.any? %>
    <p class="mb-3 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs leading-relaxed text-amber-950">
      <%= t("vlan_ip_delete_responsibility_notice") %>
    </p>
  <% end %>

  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gradient-to-b from-gray-50 to-gray-100/80">
          <tr>
            <th scope="col" class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("ip") %></th>
            <th scope="col" class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("complete_hostname") %></th>
            <th scope="col" class="px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("short_hostname") %></th>
            <th scope="col" class="px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600">
              <abbr class="cursor-help no-underline" title="<%= t('diagnostic_agent_hostname_compliance_yes') %> / <%= t('diagnostic_agent_hostname_compliance_no') %>">●</abbr>
            </th>
            <th scope="col" class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("additional_information") %></th>
            <th scope="col" class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("notes") %></th>
            <th scope="col" class="w-px whitespace-nowrap px-3 py-3.5 text-right text-xs font-semibold uppercase tracking-wider text-gray-600">
              <span class="sr-only"><%= t("destroy") %></span>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 bg-white">
          <% @vlan.ips.each do |ip| %>
            <tr class="<%= "bg-red-50/80" if ip.default_gateway_row?(@vlan) %> transition-colors hover:bg-gray-50/90">
              <td class="whitespace-nowrap px-5 py-4 text-sm font-medium">
                <%= link_to ip.address, ip_path(ip), title: t("show"), class: "font-mono text-indigo-600 hover:text-indigo-500" %>
              </td>
              <td class="px-5 py-4 text-sm text-gray-700">
                <%= ip_hostname_with_descriptor_markup(ip) %>
                <% if ip.hostname_alias.present? and ip.host.present? %>
                  <div class="mt-1">
                    <span class="inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-200">
                      <%= t("hostname_alias_with_host") %>: <%= ip.host.name %>
                    </span>
                  </div>
                <% end %>
                <% if ip.host.nil? and ip.hostname_alias.nil? %>
                  <div class="mt-2">
                    <%= link_to "+", add_host_to_ip_path(ip), class: "inline-flex items-center rounded-md bg-indigo-600 px-2 py-1 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500" %>
                  </div>
                <% end %>
              </td>
              <td class="whitespace-nowrap px-5 py-4 text-center text-sm text-gray-600"><%= ip.short_hostname %></td>
              <td class="whitespace-nowrap px-5 py-4 text-center text-sm text-gray-600">
                <% if ip.short_hostname.present? %>
                  <% if ip.diagnostic_agent_hostname_compliance? %>
                    <span class="text-emerald-600" title="<%= t('diagnostic_agent_hostname_compliance_yes') %>">●</span>
                  <% else %>
                    <span class="text-red-600" title="<%= t('diagnostic_agent_hostname_compliance_no') %>">●</span>
                  <% end %>
                <% end %>
              </td>
              <td class="px-5 py-4 text-sm text-gray-600">
                <% if ip.host.present? && ip.host.other_ips(ip.address).present? %>
                  <div class="overflow-hidden rounded-lg border border-gray-200">
                    <table class="min-w-full divide-y divide-gray-100 text-xs">
                      <tbody class="divide-y divide-gray-50 bg-white">
                        <% ip.host.other_ips(ip.address).each do |other_ip| %>
                          <tr>
                            <td class="px-2 py-1.5 font-medium text-indigo-600"><%= link_to other_ip.address, ip_path(other_ip), class: "hover:text-indigo-500" %></td>
                            <td class="px-2 py-1.5 text-gray-600"><%= other_ip.short_hostname %></td>
                            <td class="px-2 py-1.5 text-center">
                              <% if other_ip.short_hostname.present? %>
                                <span class="<%= other_ip.diagnostic_agent_hostname_compliance? ? "text-emerald-500" : "text-red-500" %>">●</span>
                              <% end %>
                            </td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  </div>
                <% end %>
              </td>
              <td class="px-5 py-4 text-sm text-gray-600">
                <% if ip.host.present? %><%= ip.host.description.html_safe %><% end %>
              </td>
              <td class="whitespace-nowrap px-3 py-4 text-right align-top">
                <%= link_to ip_path(ip, from_vlan: @vlan.id),
                  data: { turbo_method: :delete },
                  class: "inline-flex min-h-8 min-w-8 items-center justify-center rounded-md text-sm font-semibold text-red-600 ring-1 ring-inset ring-red-200 hover:bg-red-50",
                  title: t("destroy") do %>
                  <span aria-hidden="true">×</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
