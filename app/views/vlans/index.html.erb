<%= render '/common/header' %>
<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-bold text-gray-800"><%= t('vlans') %> (<%= @vlans.count.to_s %>)</h1>
  <%= link_to t('add_vlan'), new_vlan_path, class: 'bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded shadow transition duration-150 ease-in-out' %>
</div>

<% if notice.present? %>
  <div class="bg-blue-100 border-l-4 border-blue-500 text-blue-700 p-4 mb-4 shadow-sm" role="alert">
    <%= notice %>
  </div>
<% end %>

<% if @vlans.present? %>
  <div class="overflow-x-auto bg-white rounded-lg shadow overflow-hidden border border-gray-200">
    <table class="min-w-full divide-y divide-gray-200" id="tableofrows">
      <thead class="bg-gray-50">
        <tr>
          <th width="5%" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider border-b"><%= t('id') %></th>
          <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider border-b"><%= t('name') %></th>
          <th width="15%" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider border-b"><%= t('network') %></th>
          <th width="10%" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider border-b"><%= t('gateway') %></th>
          <th width="10%" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider border-b"><%= t('ips') %><br /><%= t('total') %> / <%= t('used') %></th>
          <th width="5%" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider border-b"><%= t('notes') %></th>
        </tr>
      </thead>

      <tbody class="bg-white divide-y divide-gray-200">
        <% @vlans.each do |vlan| %>
          <tr class="hover:bg-gray-50 transition-colors duration-150">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-900 border-b text-center"><%= vlan.number %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 border-b text-center">
              <div class="font-medium text-gray-900"><%= vlan.name %></div>
              <% if vlan.ips.empty? %>
                <div class="mt-1 text-xs">
                  <span class="text-red-600">ipcalc <%= vlan.network %>/<%= vlan.netmask %></span>
                  <%= link_to t('generate'), generate_network_path(vlan), class: "ml-1 text-blue-600 hover:text-blue-800 underline" %>
                </div>
              <% end %>

              <div class="mt-2 flex justify-center space-x-2">
                <%= link_to t('edit'), edit_vlan_path(vlan), class: 'text-blue-600 hover:text-blue-800 hover:underline text-xs' %>
                <%= link_to t('destroy'), vlan, data: { turbo_method: :delete, turbo_confirm: t('are_you_sure') }, class: 'text-red-600 hover:text-red-800 hover:underline text-xs' %>
              </div>

            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-blue-600 hover:text-blue-800 border-b text-center">
              <%= link_to "#{vlan.network}/#{vlan.netmask}", vlan_path(vlan), class: "underline" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 border-b text-center"><%= vlan.gateway %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 border-b text-center">
              <span class="px-2 py-1 bg-gray-100 rounded text-xs"><%= vlan.ips.count.to_s %> / <%= vlan.used_ips %></span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 border-b text-center">
              <% if vlan.include_in_etc_hosts == false %>
                <%= image_tag 'edit-delete.png', title: t('not_include_in_hosts_file'), class: "inline-block w-5 h-5" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="bg-blue-100 border-l-4 border-blue-500 text-blue-700 p-4 shadow-sm" role="alert">
    <%= t('not_found_vlans') %>
  </div>
<% end %>
