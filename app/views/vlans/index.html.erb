<%= render "/common/header" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-0 pb-10">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-gray-900"><%= t("vlans") %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= t("admin_crud_list_subtitle", count: @vlans.count) %></p>
    </div>
    <%= link_to t("add_vlan"), new_vlan_path, class: "inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
  </div>

  <%= render "common/admin_flash" %>

  <%= render "common/admin_section_intro", section: :vlans %>

  <% if @vlans.present? %>
    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200" id="tableofrows">
          <thead class="bg-gradient-to-b from-gray-50 to-gray-100/80">
            <tr>
              <th scope="col" class="w-[5%] px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("id") %></th>
              <th scope="col" class="px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("name") %></th>
              <th scope="col" class="w-[15%] px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("network") %></th>
              <th scope="col" class="w-[10%] px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("gateway") %></th>
              <th scope="col" class="w-[12%] px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("ips") %><br /><span class="font-normal normal-case text-gray-500"><%= t("total") %> / <%= t("used") %></span></th>
              <th scope="col" class="w-[8%] px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("notes") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% @vlans.each do |vlan| %>
              <tr class="transition-colors hover:bg-gray-50/90">
                <td class="px-5 py-4 text-center text-sm font-mono text-gray-900"><%= vlan.number %></td>
                <td class="px-5 py-4 text-center text-sm text-gray-900">
                  <div class="font-semibold text-gray-900"><%= vlan.name %></div>
                  <% if vlan.ips.empty? %>
                    <div class="mt-2 text-xs text-red-600">
                      ipcalc <%= vlan.network %>/<%= vlan.netmask %>
                      <%= link_to t("generate"), generate_network_path(vlan), class: "ml-1 font-medium text-indigo-600 hover:text-indigo-500 underline" %>
                    </div>
                  <% end %>
                  <div class="mt-2 text-center text-xs">
                    <%= link_to t("add_ip_to_vlan"), new_ip_vlan_path(vlan), class: "font-medium text-indigo-600 hover:text-indigo-500" %>
                  </div>
                  <div class="mt-3 flex flex-wrap justify-center gap-2">
                    <%= link_to t("edit"), edit_vlan_path(vlan), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
                    <span class="text-gray-300" aria-hidden="true">|</span>
                    <%= link_to t("destroy"), vlan, data: { turbo_method: :delete, turbo_confirm: t("are_you_sure") }, class: "text-sm font-medium text-red-600 hover:text-red-500" %>
                  </div>
                </td>
                <td class="px-5 py-4 text-center text-sm">
                  <%= link_to "#{vlan.network}/#{vlan.netmask}", vlan_path(vlan), class: "font-mono text-indigo-600 hover:text-indigo-500 underline" %>
                </td>
                <td class="px-5 py-4 text-center text-sm text-gray-700 font-mono"><%= vlan.gateway %></td>
                <td class="px-5 py-4 text-center text-sm text-gray-900">
                  <span class="inline-flex rounded-md bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-800 ring-1 ring-inset ring-gray-200"><%= vlan.ips.count.to_s %> / <%= vlan.used_ips %></span>
                </td>
                <td class="px-5 py-4 text-center text-sm text-gray-900">
                  <% if vlan.include_in_etc_hosts == false %>
                    <%= image_tag "edit-delete.png", title: t("not_include_in_hosts_file"), class: "inline-block h-5 w-5 mx-auto" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="rounded-lg border border-amber-100 bg-amber-50 px-4 py-3 text-sm text-amber-900 shadow-sm" role="status">
      <%= t("not_found_vlans") %>
    </div>
  <% end %>
</div>
