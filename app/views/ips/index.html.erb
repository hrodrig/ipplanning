<%= render "/common/header" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-0 pb-10">
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900"><%= t("ips") %></h1>
    <p class="mt-2 text-sm text-gray-600">
      <%= t("ips_total") %>:
      <span class="font-semibold text-indigo-600"><%= @ips.count.to_s %></span>
      <span class="mx-2 text-gray-300" aria-hidden="true">·</span>
      <%= t("ips_used") %>:
      <span class="font-semibold text-emerald-600"><%= Ip.used_ips %></span>
    </p>
  </div>

  <%= render "common/admin_flash" %>

  <%= render "common/admin_section_intro", section: :ips %>

  <% if @orphaned_ips.present? %>
    <div class="mb-8 rounded-lg border border-red-100 bg-red-50 px-4 py-3 shadow-sm text-sm text-red-900" role="alert">
      <%= t("orphaned_ips_message").html_safe %>
    </div>
  <% end %>

  <% if @vlans.present? %>
    <div
      class="space-y-0"
      data-controller="ip-index-filter"
      data-ip-index-filter-matches-template-value="<%= h(t("ips_filter_matches")) %>"
    >
      <%= render "ips/index_filter", suffix: "admin", show_no_results: true %>
      <% @vlans.each do |vlan| %>
      <section class="mb-12 rounded-xl border border-gray-200 bg-gray-50/60 p-6 shadow-sm last:mb-0" data-ip-vlan-section>
        <div class="mb-6 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gradient-to-b from-gray-50 to-gray-100/80">
                <tr>
                  <th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("vlan_id") %></th>
                  <th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("vlan_name") %></th>
                  <th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("vlan_descriptor") %></th>
                  <th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("network") %></th>
                  <th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("netmask") %></th>
                  <th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("gateway") %></th>
                  <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("notes") %></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 bg-white">
                <tr>
                  <td class="px-4 py-3 text-center text-sm font-mono text-gray-900"><%= vlan.number %></td>
                  <td class="px-4 py-3 text-center text-sm font-semibold text-gray-900"><%= vlan.name %></td>
                  <td class="px-4 py-3 text-center text-sm text-gray-700"><%= vlan.descriptor %></td>
                  <td class="px-4 py-3 text-center text-sm font-mono text-gray-700"><%= vlan.network %></td>
                  <td class="px-4 py-3 text-center text-sm font-mono text-gray-700"><%= vlan.netmask %></td>
                  <td class="px-4 py-3 text-center text-sm font-mono text-gray-700"><%= vlan.gateway %></td>
                  <td class="px-4 py-3 text-sm text-gray-600">
                    <pre class="whitespace-pre-wrap font-sans text-sm leading-relaxed"><%= vlan.notes %></pre>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <% if vlan.ips.count == 0 %>
          <p class="py-6 text-center text-sm italic text-gray-500"><%= t("not_assigned_ips") %></p>
        <% else %>
          <%= render "vlan", vlan: vlan, show_meta: false %>
        <% end %>
      </section>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-lg border border-amber-100 bg-amber-50 px-4 py-3 text-sm text-amber-900 shadow-sm" role="status">
      <%= t("not_found_vlans_ips") %>
    </div>
  <% end %>

  <div class="mt-12 overflow-hidden rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="border-b border-gray-100 pb-3 text-lg font-bold tracking-tight text-gray-900"><%= t("legend") %></h2>
    <ul class="mt-6 grid grid-cols-1 gap-3 md:grid-cols-2 lg:grid-cols-3">
      <li class="flex items-center gap-3 rounded-lg border border-transparent p-3 transition hover:border-gray-100 hover:bg-gray-50">
        <%= image_tag "edit-delete.png", title: t("legend_not_include_in_hosts_file"), class: "h-6 w-6 shrink-0" %>
        <span class="text-sm text-gray-700"><%= t("legend_not_include_in_hosts_file") %></span>
      </li>
      <li class="flex items-center gap-3 rounded-lg border border-transparent p-3 transition hover:border-gray-100 hover:bg-gray-50">
        <%= image_tag "network-error.png", title: t("legend_not_use_vlan_descriptor"), class: "h-6 w-6 shrink-0" %>
        <span class="text-sm text-gray-700"><%= t("legend_not_use_vlan_descriptor") %></span>
      </li>
      <li class="flex items-center gap-3 rounded-lg border border-transparent p-3 transition hover:border-gray-100 hover:bg-gray-50">
        <%= image_tag "task-due.png", title: t("legend_not_use_hostname_alias"), class: "h-6 w-6 shrink-0" %>
        <span class="text-sm text-gray-700"><%= t("legend_not_use_hostname_alias") %></span>
      </li>
      <li class="flex items-center gap-3 rounded-lg border border-transparent p-3 transition hover:border-gray-100 hover:bg-gray-50">
        <%= image_tag "geany-close-all.png", title: t("legend_ip_reserved"), class: "h-6 w-6 shrink-0" %>
        <span class="text-sm text-gray-700"><%= t("legend_ip_reserved") %></span>
      </li>
      <li class="flex items-center gap-3 rounded-lg border border-transparent p-3 transition hover:border-gray-100 hover:bg-gray-50">
        <%= image_tag "application-exit.png", title: t("legend_not_use_domain_name"), class: "h-6 w-6 shrink-0" %>
        <span class="text-sm text-gray-700"><%= t("legend_not_use_domain_name") %></span>
      </li>
    </ul>
  </div>
</div>
