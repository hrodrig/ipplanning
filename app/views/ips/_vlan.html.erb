<% if local_assigns.fetch(:show_meta, true) %>
  <ul class="mb-6 space-y-2 rounded-xl border border-gray-200 bg-white p-4 text-sm shadow-sm">
    <li><span class="font-semibold text-gray-700"><%= t("vlan_id") %> / <%= t("vlan_name") %>:</span> <span class="text-gray-900"><%= vlan.number.to_s %> / <%= vlan.name %></span></li>
    <% if vlan.descriptor.present? %><li><span class="font-semibold text-gray-700"><%= t("vlan_descriptor") %>:</span> <span class="text-gray-900"><%= vlan.descriptor %></span></li><% end %>
    <li><span class="font-semibold text-gray-700"><%= t("network") %> / <%= t("netmask") %> / <%= t("gateway") %>:</span> <span class="font-mono text-gray-900"><%= vlan.network %> / <%= vlan.netmask.to_s %> / <%= vlan.gateway %></span></li>
    <li><span class="font-semibold text-gray-700"><%= t("ips_assigned") %> / <%= t("ips_used") %>:</span> <span class="text-gray-900"><%= vlan.ips.count.to_s %> / <%= vlan.used_ips %></span></li>
    <li><span class="font-semibold text-gray-700"><%= t("include_in_etc_hosts") %>:</span> <%= get_icon vlan.include_in_etc_hosts %></li>
    <% if vlan.notes.present? %><li><span class="font-semibold text-gray-700"><%= t("notes") %>:</span> <span class="text-gray-900"><%= vlan.notes.html_safe %></span></li><% end %>
  </ul>
<% end %>

<div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
  <div class="overflow-x-auto">
  <table class="min-w-full divide-y divide-gray-200" id="<%= dom_id(vlan, :ip_table) %>">
    <thead class="bg-gradient-to-b from-gray-50 to-gray-100/80">
      <tr>
        <th scope="col" class="w-[28%] px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("address") %></th>
        <th scope="col" class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("complete_hostname") %></th>
        <th scope="col" class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("hostname") %></th>
        <th scope="col" class="w-[10%] px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("extras_ips") %></th>
        <th scope="col" class="w-[10%] px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("notes") %></th>
        <th scope="col" class="px-4 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600">&nbsp;</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 bg-white">
      <% vlan.ips.each do |ip| %>
      <% 
        row_class = "hover:bg-blue-50 transition-colors duration-150"
        if ip.address == vlan.gateway
          row_class = "bg-red-50 hover:bg-red-100"
        elsif ip.is_reserved?
          row_class = "bg-yellow-50 hover:bg-yellow-100"
        end
      %>
      <tr class="<%= row_class %>">
        <td class="px-4 py-3 text-center text-sm text-gray-900">
          <a name="<%= ip.address %>" class="font-mono font-medium">
            <%= ip.address %>
            <div class="mt-2 flex justify-center gap-2">
              <%= link_to t("edit"), edit_ip_path(ip), class: "text-xs font-medium text-indigo-600 hover:text-indigo-500" %>
              <%= link_to t("destroy"), ip, data: { turbo_method: :delete, turbo_confirm: t("are_you_sure_to_delete_this_ip") }, class: "text-xs font-medium text-red-600 hover:text-red-500" %>
            </div>
          </a>
        </td>
        <td class="px-4 py-3 text-sm text-gray-900">
          <% if ip.host.nil? and ip.hostname_alias.nil? and ip.is_reserved.nil? %>
            <div class="text-center">
              <%= link_to '+', add_host_to_ip_path(ip), title: t('assign_this_ip_to_host'), class: 'inline-flex items-center justify-center w-6 h-6 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-full text-xs transition duration-150 ease-in-out' %>
            </div>
          <% else %>
            <div class="text-gray-900 font-medium">
              <% if ip.is_reserved? %>
                <span class="italic text-gray-600"><%= ip.long_hostname %></span>
              <% else %>
                <%= ip_hostname_with_descriptor_markup(ip) %>
              <% end %>
            </div>
            <% if ip.hostname_alias.present? and ip.host.present? %>
              <div class="mt-1">
                <span class="px-2 py-0.5 text-xs font-semibold text-gray-800 bg-gray-100 border border-gray-300 rounded">
                  <%= t('hostname_alias_with_host') %>: <%= ip.host.name %>
                </span>
              </div>
            <% end %>
          <% end %>
        </td>
        <td class="px-4 py-3 text-center text-sm text-gray-900">
          <%= ip.short_hostname %>
        </td>
        <td class="px-4 py-3 text-sm text-gray-900">
          <% if ip.host.present? %>
            <div class="text-xs text-gray-600">
              <%= host_linked_ip_addresses_markup(ip.host, except_address: ip.address) %>
            </div>
          <% end %>
        </td>
        <td class="px-4 py-3 text-sm text-gray-600">
          <% if ip.notes? %>
            <%= ip.notes %>
          <% end %>
        </td>
        <td class="px-4 py-3 text-center text-sm text-gray-900">
          <div class="flex items-center justify-center space-x-1">
            <% if ip.include_in_etc_hosts == false %>
              <%= image_tag 'edit-delete.png', title: t('not_include_in_hosts_file'), class: "w-5 h-5" %>
            <% else %>
              <div class="w-5 h-5"></div>
            <% end %>
            <% if ip.use_vlan_descriptor == false %>
              <%= image_tag 'network-error.png', title: t('not_use_vlan_descriptor'), class: "w-5 h-5" %>
            <% else %>
              <div class="w-5 h-5"></div>
            <% end %>
            <% if ip.host.present? %>
              <% if ip.hostname_alias.present? %>
                <%= image_tag 'task-due.png', title: t('use_hostname_alias') + ip.host.name, class: "w-5 h-5" %>
              <% else %>
                <div class="w-5 h-5"></div>
              <% end %>
            <% else %>
              <div class="w-5 h-5"></div>
            <% end %>
            <% if ip.is_reserved == true %>
              <%= image_tag 'geany-close-all.png', title: t('is_reserved'), class: "w-5 h-5" %>
            <% else %>
              <div class="w-5 h-5"></div>
            <% end %>
            <% if ip.use_domain_name == false %>
              <%= image_tag 'application-exit.png', title: t('not_use_domain_name'), class: "w-5 h-5" %>
            <% else %>
              <div class="w-5 h-5"></div>
            <% end %>
          </div>
        </td>
      </tr>
      <% end %>
    </tbody>
  </table>
  </div>
</div>
