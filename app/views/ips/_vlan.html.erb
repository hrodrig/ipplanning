<ul class="bg-gray-50 p-4 rounded-lg border border-gray-200 mb-6 space-y-1 shadow-sm">
  <li><strong class="text-gray-700"><%= t('vlan_id') %> / <%= t('vlan_name') %></strong>: <span class="text-gray-900"><%= vlan.number.to_s %> / <%= vlan.name %></span></li>
  <% if vlan.descriptor.present? %><li><strong class="text-gray-700"><%= t('vlan_descriptor') %></strong>: <span class="text-gray-900"><%= vlan.descriptor %></span></li><% end %>
  <li><strong class="text-gray-700"><%= t('network') %> / <%= t('netmask') %> / <%= t('gateway') %></strong>: <span class="text-gray-900"><%= vlan.network %> / <%= vlan.netmask.to_s %> / <%= vlan.gateway %></span></li>
  <li><strong class="text-gray-700"><%= t('ips_assigned') %> / <%= t('ips_used') %></strong>: <span class="text-gray-900"><%= vlan.ips.count.to_s %> / <%= vlan.used_ips %></span></li>
  <li><strong class="text-gray-700"><%= t('include_in_etc_hosts') %></strong>: <%= get_icon vlan.include_in_etc_hosts %></li>
  <% if vlan.notes.present? %><li><strong class="text-gray-700"><%= t('notes') %></strong>: <span class="text-gray-900"><%= vlan.notes.html_safe %></span></li><% end %>
</ul>

<div class="overflow-x-auto bg-white rounded-lg shadow overflow-hidden border border-gray-200">
  <table class="min-w-full divide-y divide-gray-200" id="tableofrows">
    <thead class="bg-gray-50">
      <tr>
        <th width="30%" class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider border-b"><%= t('address') %></th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider border-b"><%= t('complete_hostname') %></th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider border-b"><%= t('hostname') %></th>
        <th width="10%" class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider border-b"><%= t('extras_ips') %></th>
        <th width="10%" class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider border-b"><%= t('notes') %></th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider border-b">&nbsp;</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% vlan.ips.each do |ip| %>
      <% 
        row_class = "hover:bg-blue-50 transition-colors duration-150"
        if ip.address == vlan.gateway
          row_class = "bg-red-50 hover:bg-red-100"
        elsif ip.is_reserved?
          row_class = "bg-yellow-50 hover:bg-yellow-100"
        end
      %>
      <tr class="<%= row_class %>">
        <td class="px-4 py-3 text-sm text-gray-900 border-b" style="text-align: center;">
          <a name="<%= ip.address %>" class="font-mono font-medium">
            <%= ip.address %>
            <div class="mt-2 flex justify-center space-x-2">
              <%= link_to t('edit'), edit_ip_path(ip), class: 'text-blue-600 hover:text-blue-800 hover:underline text-xs' %>
              <%= link_to t('destroy'), ip, data: { turbo_method: :delete, turbo_confirm: t('are_you_sure_to_delete_this_ip') }, class: 'text-red-600 hover:text-red-800 hover:underline text-xs' %>
            </div>
          </a>
        </td>
        <td class="px-4 py-3 text-sm text-gray-900 border-b">
          <% if ip.host.nil? and ip.hostname_alias.nil? and ip.is_reserved.nil? %>
            <div class="text-center">
              <%= link_to '+', add_host_to_ip_path(ip), title: t('assign_this_ip_to_host'), class: 'inline-flex items-center justify-center w-6 h-6 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-full text-xs transition duration-150 ease-in-out' %>
            </div>
          <% else %>
            <div class="text-gray-900 font-medium">
              <% if ip.is_reserved? %>
                <span class="italic text-gray-600"><%= ip.long_hostname %></span>
              <% else %>
                <%= ip.hostname_with_descriptor.html_safe %>
              <% end %>
            </div>
            <% if ip.hostname_alias.present? and ip.host.present? %>
              <div class="mt-1">
                <span class="px-2 py-0.5 text-xs font-semibold text-gray-800 bg-gray-100 border border-gray-300 rounded">
                  <%= t('hostname_alias_with_host') %>: <%= ip.host.name %>
                </span>
              </div>
            <% end %>
          <% end %>
        </td>
        <td class="px-4 py-3 text-sm text-gray-900 border-b text-center">
          <%= ip.short_hostname %>
        </td>
        <td class="px-4 py-3 text-sm text-gray-900 border-b">
          <% if ip.host.present? %>
            <div class="text-xs text-gray-600">
              <%= ip.host.all_ips_except_this(ip.address).html_safe %>
            </div>
          <% end %>
        </td>
        <td class="px-4 py-3 text-sm text-gray-600 border-b">
          <% if ip.notes? %>
            <%= ip.notes %>
          <% end %>
        </td>
        <td class="px-4 py-3 text-sm text-gray-900 border-b text-center">
          <div class="flex items-center justify-center space-x-1">
            <% if ip.include_in_etc_hosts == false %>
              <%= image_tag 'edit-delete.png', title: t('not_include_in_hosts_file'), class: "w-5 h-5" %>
            <% else %>
              <div class="w-5 h-5"></div>
            <% end %>
            <% if ip.use_vlan_descriptor == false %>
              <%= image_tag 'network-error.png', title: t('not_use_vlan_descriptor'), class: "w-5 h-5" %>
            <% else %>
              <div class="w-5 h-5"></div>
            <% end %>
            <% if ip.host.present? %>
              <% if ip.hostname_alias.present? %>
                <%= image_tag 'task-due.png', title: t('use_hostname_alias') + ip.host.name, class: "w-5 h-5" %>
              <% else %>
                <div class="w-5 h-5"></div>
              <% end %>
            <% else %>
              <div class="w-5 h-5"></div>
            <% end %>
            <% if ip.is_reserved == true %>
              <%= image_tag 'geany-close-all.png', title: t('is_reserved'), class: "w-5 h-5" %>
            <% else %>
              <div class="w-5 h-5"></div>
            <% end %>
            <% if ip.use_domain_name == false %>
              <%= image_tag 'application-exit.png', title: t('not_use_domain_name'), class: "w-5 h-5" %>
            <% else %>
              <div class="w-5 h-5"></div>
            <% end %>
          </div>
        </td>
      </tr>
      <% end %>
    </tbody>
  </table>
</div>
