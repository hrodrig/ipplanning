<% if local_assigns.fetch(:show_meta, true) %>
  <ul class="mb-6 space-y-2 rounded-xl border border-gray-200 bg-white p-4 text-sm shadow-sm">
    <li><span class="font-semibold text-gray-700"><%= t("vlan_id") %> / <%= t("vlan_name") %>:</span> <span class="text-gray-900"><%= vlan.number.to_s %> / <%= vlan.name %></span></li>
    <% if vlan.descriptor.present? %><li><span class="font-semibold text-gray-700"><%= t("vlan_descriptor") %>:</span> <span class="text-gray-900"><%= vlan.descriptor %></span></li><% end %>
    <li><span class="font-semibold text-gray-700"><%= t("network") %> / <%= t("netmask") %> / <%= t("gateway") %>:</span> <span class="font-mono text-gray-900"><%= vlan.network %> / <%= vlan.netmask.to_s %> / <%= vlan.gateway %></span></li>
    <li><span class="font-semibold text-gray-700"><%= t("ips_assigned") %> / <%= t("ips_used") %>:</span> <span class="text-gray-900"><%= vlan.ips.count.to_s %> / <%= vlan.used_ips %></span></li>
    <li><span class="font-semibold text-gray-700"><%= t("include_in_etc_hosts") %>:</span> <%= get_icon vlan.include_in_etc_hosts %></li>
    <% if vlan.notes.present? %><li><span class="font-semibold text-gray-700"><%= t("notes") %>:</span> <span class="text-gray-900"><%= vlan.notes.html_safe %></span></li><% end %>
  </ul>
<% end %>

<% sorted_ips = vlan.ips.order_by_ipv4_address.to_a %>
<% chunk_size = 64 %>
<% chunks = sorted_ips.each_slice(chunk_size).to_a %>
<% multichunk = chunks.size > 1 %>
<% scroll_single = !multichunk && sorted_ips.size >= 36 %>

<% if multichunk %>
  <p class="mb-3 text-xs text-gray-500"><%= t("ips_chunk_index_hint") %></p>
  <div class="space-y-3">
    <% chunks.each_with_index do |chunk, idx| %>
      <% chunk_used = chunk.count { |ip| ip.host.present? } %>
      <details class="ip-index-chunk overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm" data-default-open="<%= idx.zero? %>" <%= "open" if idx.zero? %>>
        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 bg-gradient-to-b from-slate-50 to-slate-50/90 px-4 py-3 text-left text-sm text-gray-900 hover:from-slate-100 hover:to-slate-50 [&::-webkit-details-marker]:hidden [&::marker]:hidden">
          <span>
            <span class="font-semibold text-indigo-700"><%= t("ips_chunk_range", from: chunk.first.address, to: chunk.last.address) %></span>
            <span class="text-gray-600"> — <%= t("ips_chunk_meta", count: chunk.size, used: chunk_used) %></span>
          </span>
          <svg class="ip-index-chunk-chevron h-5 w-5 shrink-0 text-gray-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="max-h-[min(70vh,520px)] overflow-auto border-t border-gray-200">
          <table class="min-w-full divide-y divide-gray-200" id="<%= idx.zero? ? dom_id(vlan, :ip_table) : "#{dom_id(vlan, :ip_table)}_chunk_#{idx}" %>" data-controller="ip-table-sort">
            <%= render "ips/ip_table_head" %>
            <tbody class="divide-y divide-gray-100 bg-white">
              <% chunk.each do |ip| %>
                <%= render "ips/ip_table_row", ip: ip, vlan: vlan %>
              <% end %>
            </tbody>
          </table>
        </div>
      </details>
    <% end %>
  </div>
<% else %>
  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm" data-ip-table-wrap>
    <div class="<%= scroll_single ? "max-h-[min(70vh,560px)] overflow-auto" : "overflow-x-auto" %>">
      <table class="min-w-full divide-y divide-gray-200" id="<%= dom_id(vlan, :ip_table) %>" data-controller="ip-table-sort">
        <%= render "ips/ip_table_head" %>
        <tbody class="divide-y divide-gray-100 bg-white">
          <% sorted_ips.each do |ip| %>
            <%= render "ips/ip_table_row", ip: ip, vlan: vlan %>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
