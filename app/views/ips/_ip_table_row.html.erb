<%# locals: ip, vlan %>
<% 
  row_class = "hover:bg-blue-50 transition-colors duration-150"
  if ip.default_gateway_row?(vlan)
    row_class = "bg-red-50 hover:bg-red-100"
  elsif ip.is_reserved?
    row_class = "bg-yellow-50 hover:bg-yellow-100"
  end
  search_blob = ERB::Util.html_escape(ip.searchable_text)
  sort_complete = ERB::Util.html_escape(ip.hostname_with_descriptor.to_s.downcase.strip)
  sort_short = ERB::Util.html_escape(ip.short_hostname.to_s.downcase.strip)
  sort_notes = ERB::Util.html_escape(ip.notes.to_s.downcase.strip)
  sort_extras = ERB::Util.html_escape(ip.sort_key_extras_ips)
%>
<tr class="<%= row_class %>" data-ip-search="<%= search_blob %>" data-sort-ip="<%= ip.ipv4_sort_integer %>" data-sort-complete="<%= sort_complete %>" data-sort-short="<%= sort_short %>" data-sort-notes="<%= sort_notes %>" data-sort-extras="<%= sort_extras %>">
  <td class="px-4 py-3 text-center text-sm text-gray-900">
    <a name="<%= ip.address %>" class="font-mono font-medium">
      <%= ip.address %>
      <div class="mt-2 flex justify-center gap-2">
        <%= link_to t("edit"), edit_ip_path(ip), class: "text-xs font-medium text-indigo-600 hover:text-indigo-500" %>
        <%= link_to t("destroy"), ip, data: { turbo_method: :delete, turbo_confirm: t("are_you_sure_to_delete_this_ip") }, class: "text-xs font-medium text-red-600 hover:text-red-500" %>
      </div>
    </a>
  </td>
  <td class="px-4 py-3 text-sm text-gray-900">
    <% if ip.host.nil? and ip.hostname_alias.nil? and ip.is_reserved.nil? %>
      <div class="text-center">
        <%= link_to '+', add_host_to_ip_path(ip), title: t('assign_this_ip_to_host'), class: 'inline-flex items-center justify-center w-6 h-6 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-full text-xs transition duration-150 ease-in-out' %>
      </div>
    <% else %>
      <div class="text-gray-900 font-medium">
        <% if ip.is_reserved? %>
          <span class="italic text-gray-600"><%= ip.long_hostname %></span>
        <% else %>
          <%= ip_hostname_with_descriptor_markup(ip) %>
        <% end %>
      </div>
      <% if ip.hostname_alias.present? and ip.host.present? %>
        <div class="mt-1">
          <span class="px-2 py-0.5 text-xs font-semibold text-gray-800 bg-gray-100 border border-gray-300 rounded">
            <%= t('hostname_alias_with_host') %>: <%= ip.host.name %>
          </span>
        </div>
      <% end %>
    <% end %>
  </td>
  <td class="px-4 py-3 text-center text-sm text-gray-900">
    <%= ip.short_hostname %>
  </td>
  <td class="px-4 py-3 text-sm text-gray-900">
    <% if ip.host.present? %>
      <div class="text-xs text-gray-600">
        <%= host_linked_ip_addresses_markup(ip.host, except_address: ip.address) %>
      </div>
    <% end %>
  </td>
  <td class="px-4 py-3 text-sm text-gray-600">
    <% if ip.notes? %>
      <%= ip.notes %>
    <% end %>
  </td>
  <td class="px-4 py-3 text-center text-sm text-gray-900">
    <div class="flex items-center justify-center space-x-1">
      <% if ip.include_in_etc_hosts == false %>
        <%= image_tag 'edit-delete.png', title: t('not_include_in_hosts_file'), class: "w-5 h-5" %>
      <% else %>
        <div class="w-5 h-5"></div>
      <% end %>
      <% if ip.use_vlan_descriptor == false %>
        <%= image_tag 'network-error.png', title: t('not_use_vlan_descriptor'), class: "w-5 h-5" %>
      <% else %>
        <div class="w-5 h-5"></div>
      <% end %>
      <% if ip.host.present? %>
        <% if ip.hostname_alias.present? %>
          <%= image_tag 'task-due.png', title: t('use_hostname_alias') + ip.host.name, class: "w-5 h-5" %>
        <% else %>
          <div class="w-5 h-5"></div>
        <% end %>
      <% else %>
        <div class="w-5 h-5"></div>
      <% end %>
      <% if ip.is_reserved == true %>
        <%= image_tag 'geany-close-all.png', title: t('is_reserved'), class: "w-5 h-5" %>
      <% else %>
        <div class="w-5 h-5"></div>
      <% end %>
      <% if ip.use_domain_name == false %>
        <%= image_tag 'application-exit.png', title: t('not_use_domain_name'), class: "w-5 h-5" %>
      <% else %>
        <div class="w-5 h-5"></div>
      <% end %>
    </div>
  </td>
</tr>
