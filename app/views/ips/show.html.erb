<%= render layout: "common/admin_resource_form", locals: {
  heading: "#{t('ip')}: #{@ip.address}",
  index_path: ips_path,
  index_label: t("ips"),
  current_label: @ip.address.to_s,
  back_path: ips_path,
  primary_action_path: edit_ip_path(@ip),
  width_class: "max-w-4xl",
  form_card: false
} do %>
  <div class="mb-8">
    <% if @ip.include_in_etc_hosts.present? %>
      <div class="rounded-xl border border-indigo-100 bg-indigo-50/80 p-6 shadow-sm">
        <div class="flex flex-wrap items-center gap-4 font-mono text-lg text-indigo-950">
          <span class="rounded-lg bg-indigo-600 px-3 py-1 text-sm font-semibold text-white shadow-sm"><%= @ip.address %></span>
          <span><%= @ip.long_hostname %></span>
          <span class="text-sm text-indigo-600/90"><%= @ip.short_hostname %></span>
        </div>
      </div>
    <% else %>
      <div class="rounded-xl border border-red-100 bg-red-50/80 p-6 italic text-red-900 opacity-90 shadow-sm line-through grayscale">
        <div class="flex flex-wrap items-center gap-4 font-mono text-lg">
          <span class="rounded-lg bg-red-600 px-3 py-1 text-sm font-semibold text-white"><%= @ip.address %></span>
          <span><%= @ip.long_hostname %></span>
          <span class="text-sm text-red-700"><%= @ip.short_hostname %></span>
        </div>
      </div>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4">
      <h2 class="text-base font-semibold text-gray-900"><%= t("public_information") %></h2>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("vlan_descriptor_ip") %></dt>
        <dd class="mt-1 text-sm font-mono text-gray-900 sm:col-span-2 sm:mt-0">
          <%= @ip.vlan.number %> / <% if @ip.vlan.descriptor.present? %><%= @ip.vlan.descriptor %><% else %>---<% end %> / <%= @ip.address.to_s %>
        </dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("hostname") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= ip_hostname_with_descriptor_markup(@ip) %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("hostname_alias") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @ip.hostname_alias %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("complete_hostname_alias") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @ip.complete_hostname_alias %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("description") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
          <% if @ip.host.present? %><%= @ip.host.description.html_safe %><% end %>
        </dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("extras_ips") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
          <% if @ip.host.present? %><%= host_linked_ip_addresses_markup(@ip.host, except_address: @ip.address) %><% end %>
        </dd>
      </div>
    </dl>

    <div class="border-t border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4">
      <h2 class="text-base font-semibold text-gray-900"><%= t("private_information") %></h2>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("include_in_etc_hosts") %>?</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= get_icon @ip.include_in_etc_hosts %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("use_vlan_descriptor") %>?</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= get_icon @ip.use_vlan_descriptor %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("is_reserved") %>?</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= get_icon @ip.is_reserved %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("use_domain_name") %>?</dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= get_icon @ip.use_domain_name %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("notes") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
          <% if @ip.notes.present? %><%= @ip.notes %><% end %>
        </dd>
      </div>
    </dl>
  </div>
<% end %>
