<%= render '/common/header' %>

<div class="px-4 sm:px-6 lg:px-8 mt-8">
  <% if notice.present? %>
    <div class="mb-6 rounded-md bg-blue-50 p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" /></svg>
        </div>
        <div class="ml-3"><p class="text-sm text-blue-700"><%= notice %></p></div>
      </div>
    </div>
  <% end %>

  <div class="mb-8">
    <% if @ip.include_in_etc_hosts.present? %>
      <div class="rounded-lg bg-indigo-50 p-6 font-mono text-lg shadow-sm border border-indigo-100">
        <div class="flex space-x-4 items-center">
          <span class="bg-indigo-600 text-white px-3 py-1 rounded shadow-sm"><%= @ip.address %></span>
          <span class="text-indigo-900"><%= @ip.long_hostname %></span>
          <span class="text-indigo-400 text-sm"><%= @ip.short_hostname %></span>
        </div>
      </div>
    <% else %>
      <div class="rounded-lg bg-red-50 p-6 font-mono text-lg shadow-sm border border-red-100 grayscale italic opacity-75">
        <div class="flex space-x-4 items-center line-through">
          <span class="bg-red-600 text-white px-3 py-1 rounded"><%= @ip.address %></span>
          <span class="text-red-900"><%= @ip.long_hostname %></span>
          <span class="text-red-400 text-sm"><%= @ip.short_hostname %></span>
        </div>
      </div>
    <% end %>
  </div>

  <div class="overflow-hidden bg-white shadow sm:rounded-lg">
    <div class="px-4 py-6 sm:px-6 bg-gray-50 border-b border-gray-200">
      <h3 class="text-base font-semibold leading-7 text-gray-900"><%= t('public_information') %></h3>
    </div>
    <div class="border-t border-gray-100">
      <dl class="divide-y divide-gray-100">
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900"><%= t('vlan_descriptor_ip') %></dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
            <%= @ip.vlan.number %> / <% if @ip.vlan.descriptor.present? %><%= @ip.vlan.descriptor %><% else %>---<% end %> / <%= @ip.address.to_s %>
          </dd>
        </div>
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900"><%= t('hostname') %></dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @ip.hostname_with_descriptor.html_safe %></dd>
        </div>
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900"><%= t('hostname_alias') %></dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @ip.hostname_alias %></dd>
        </div>
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900"><%= t('complete_hostname_alias') %></dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= @ip.complete_hostname_alias %></dd>
        </div>
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900"><%= t('description') %></dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
            <% if @ip.host.present? %><%= @ip.host.description.html_safe %><% end %>
          </dd>
        </div>
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900"><%= t('extras_ips') %></dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
            <% if @ip.host.present? %><%= @ip.host.all_ips_except_this(@ip.address).html_safe %><% end %>
          </dd>
        </div>
      </dl>
    </div>

    <div class="px-4 py-6 sm:px-6 bg-gray-50 border-t border-b border-gray-200">
      <h3 class="text-base font-semibold leading-7 text-gray-900"><%= t('private_information') %></h3>
    </div>
    <div class="border-t border-gray-100">
      <dl class="divide-y divide-gray-100">
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900"><%= t('include_in_etc_hosts') %>?</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= get_icon @ip.include_in_etc_hosts %></dd>
        </div>
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900"><%= t('use_vlan_descriptor') %>?</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= get_icon @ip.use_vlan_descriptor %></dd>
        </div>
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900"><%= t('is_reserved') %>?</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= get_icon @ip.is_reserved %></dd>
        </div>
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900"><%= t('use_domain_name') %>?</dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0"><%= get_icon @ip.use_domain_name %></dd>
        </div>
        <div class="px-4 py-6 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-900"><%= t('notes') %></dt>
          <dd class="mt-1 text-sm leading-6 text-gray-700 sm:col-span-2 sm:mt-0">
            <% if @ip.notes.present? %><%= @ip.notes %><% end %>
          </dd>
        </div>
      </dl>
    </div>
  </div>

  <div class="mt-8 flex flex-wrap gap-4">
    <%= link_to t('back'), :back, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    <%= link_to t('hosts'), hosts_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    <%= link_to t('ips'), ips_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    <%= link_to t('vlans'), vlans_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
    <%= link_to t('edit'), edit_ip_path(@ip), class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
  </div>
</div>
