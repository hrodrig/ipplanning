<%= form_for(@host, url: create_host_to_ip_path(@ip), html: { class: "space-y-6" }) do |form| %>
  <% if host.errors.any? %>
    <div class="rounded-md bg-red-50 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800"><%= pluralize(host.errors.count, "error") %> prohibited this host from being saved:</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% host.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%= hidden_field_tag :id %>

  <div>
    <%= form.label :name, t('hostname'), class: form_label_class %>
    <div class="mt-2">
      <%= form.text_field :name, id: :host_name, class: form_control_class, placeholder: t('placeholder_hosts_hostname') %>
    </div>
  </div>

  <div>
    <%= form.label :description, t('notes'), class: form_label_class %>
    <div class="mt-2">
      <%= form.text_area :description, id: :host_description, class: form_control_class, placeholder: t('placeholder_hosts_description'), rows: 3 %>
    </div>
  </div>

  <div class="flex items-center justify-end gap-x-6 border-t border-gray-900/10 pt-6">
    <%= form.submit t('ok'), class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 cursor-pointer" %>
  </div>
<% end %>
