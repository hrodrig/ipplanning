<%= render layout: "common/admin_resource_form", locals: {
  heading: "#{t('network_switch')}: #{@network_switch.name}",
  subheading: @network_switch.equipment_model.presence,
  index_path: network_switches_path,
  index_label: t("network_switches"),
  current_label: @network_switch.name,
  back_path: network_switches_path,
  primary_action_path: edit_network_switch_path(@network_switch),
  width_class: "max-w-6xl",
  form_card: false
} do %>
  <div class="mb-10 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4">
      <h2 class="text-base font-semibold text-gray-900"><%= t("details") %></h2>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("network_switch_name") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @network_switch.name %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("network_switch_serial") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @network_switch.serial.presence || "—" %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("network_switch_equipment_model") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @network_switch.equipment_model.presence || "—" %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("network_switch_server_rack") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
          <% if @network_switch.server_rack %>
            <%= link_to @network_switch.server_rack.name, server_rack_path(@network_switch.server_rack, highlight_network_switch_id: @network_switch.id), class: "text-indigo-600 hover:text-indigo-500" %>
            <span class="text-gray-500"> · <%= @network_switch.server_rack.location.name %></span>
          <% else %>
            —
          <% end %>
        </dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("network_switch_rack_units") %> / <%= t("network_switch_rack_position_start") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
          <% if @network_switch.server_rack %>
            <%= @network_switch.rack_units %> U
            <% if @network_switch.rack_position_start.present? %>
              <span class="text-gray-500"> · U<%= @network_switch.rack_position_start %>+</span>
            <% end %>
          <% else %>
            —
          <% end %>
        </dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("network_switch_pdu_reference") %> / <%= t("network_switch_outlet_reference") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
          <%= @network_switch.pdu_reference.presence || "—" %> · <%= @network_switch.outlet_reference.presence || "—" %>
        </dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("network_switch_firmware_version") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @network_switch.firmware_version.presence || "—" %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("network_switch_firmware_updated_on") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @network_switch.firmware_updated_on ? l(@network_switch.firmware_updated_on, format: :long) : "—" %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("network_switch_management_username") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @network_switch.management_username.presence || "—" %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("network_switch_management_secret_hint") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 whitespace-pre-wrap"><%= @network_switch.management_secret_hint.presence || "—" %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("notes") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 whitespace-pre-wrap"><%= @network_switch.notes.presence || "—" %></dd>
      </div>
    </dl>
  </div>

  <% if @network_switch.server_rack %>
    <%= render "server_racks/u_diagram", server_rack: @network_switch.server_rack, highlight_network_switch: @network_switch %>
  <% end %>

  <div class="mb-10 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4 flex flex-wrap items-center justify-between gap-3">
      <h2 class="text-base font-semibold text-gray-900"><%= t("switch_ports") %></h2>
      <%= link_to t("add_switch_port"), new_network_switch_switch_port_path(@network_switch), class: "inline-flex items-center rounded-lg bg-white px-3 py-1.5 text-sm font-semibold text-indigo-700 shadow-sm ring-1 ring-inset ring-indigo-200 hover:bg-indigo-50" %>
    </div>
    <div class="p-5">
      <% if @switch_ports.any? %>
        <ul class="divide-y divide-gray-100">
          <% @switch_ports.each do |port| %>
            <li class="flex flex-wrap items-center justify-between gap-2 py-3 text-sm">
              <span class="min-w-0 flex-1">
                <span class="font-mono font-medium text-gray-900"><%= port.name %></span>
                <% pc = port.patch_connection %>
                <% if pc %>
                  <span class="mt-0.5 block text-xs text-gray-600">
                    <%= t("switch_port_patched_to") %>:
                    <%= link_to pc.host_port.host.name, host_path(pc.host_port.host), class: "font-medium text-indigo-600 hover:text-indigo-500" %>
                    · <%= pc.host_port.display_label %>
                  </span>
                <% else %>
                  <span class="mt-0.5 block text-xs text-gray-500"><%= t("switch_port_free") %></span>
                <% end %>
              </span>
              <span class="flex items-center gap-2">
                <%= link_to t("edit"), edit_network_switch_switch_port_path(@network_switch, port), class: "font-medium text-indigo-600 hover:text-indigo-500" %>
                <%= link_to t("destroy"), network_switch_switch_port_path(@network_switch, port), data: { turbo_method: :delete, turbo_confirm: t("are_you_sure") }, class: "font-medium text-red-600 hover:text-red-500" %>
              </span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-gray-500"><%= t("not_found_switch_ports") %></p>
      <% end %>
    </div>
  </div>

  <h2 class="mb-4 text-lg font-bold tracking-tight text-gray-900"><%= t("network_switch_photos") %></h2>
  <% if @network_switch.photos.attached? %>
    <div class="flex flex-wrap gap-4">
      <% @network_switch.photos.each do |file| %>
        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <% if file.representable? %>
            <%= image_tag file, class: "max-h-64 max-w-full object-contain" %>
          <% else %>
            <%= link_to file.filename.to_s, url_for(file), class: "block p-4 text-sm text-indigo-600 hover:text-indigo-500" %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-600 shadow-sm" role="status">
      <%= t("not_found_network_switch_photos") %>
    </div>
  <% end %>

  <div class="mt-10 flex flex-wrap gap-3">
    <%= link_to t("add_network_switch"), new_network_switch_path, class: "inline-flex items-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-indigo-700 shadow-sm ring-1 ring-inset ring-indigo-200 hover:bg-indigo-50" %>
  </div>
<% end %>
