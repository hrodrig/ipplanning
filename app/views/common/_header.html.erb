<div class="flex flex-col md:flex-row items-center justify-between mb-8 space-y-4 md:space-y-0">
  <div class="w-full md:w-1/3 flex justify-start">
    <%= image_tag Setting.find_by_name('HeaderLeftImage').value, class: "max-h-20" if Setting.find_by_name('HeaderLeftImage').present? %>
  </div>
  <div class="w-full md:w-1/3 text-center">
    <div class="text-xl font-semibold text-gray-700">
      <%= Setting.find_by_name('HeaderCentralTitle').value.html_safe if Setting.find_by_name('HeaderCentralTitle').present? %>
    </div>
  </div>
  <div class="w-full md:w-1/3 flex justify-end">
    <%= image_tag Setting.find_by_name('HeaderRightImage').value, class: "max-h-20" if Setting.find_by_name('HeaderRightImage').present? %>
  </div>
</div>
