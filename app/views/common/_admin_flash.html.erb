<% if flash[:notice].present? %>
  <div class="mb-6 rounded-lg border border-blue-100 bg-blue-50 px-4 py-3 shadow-sm" role="status">
    <div class="flex gap-3">
      <svg class="mt-0.5 h-5 w-5 shrink-0 text-blue-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
      </svg>
      <p class="text-sm text-blue-800"><%= flash[:notice] %></p>
    </div>
  </div>
<% end %>

<% if flash[:alert].present? %>
  <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 shadow-sm" role="alert">
    <div class="flex gap-3">
      <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
      </svg>
      <p class="text-sm text-red-900"><%= flash[:alert] %></p>
    </div>
  </div>
<% end %>
