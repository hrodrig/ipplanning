<%= form_with(model: setting, local: true, class: "space-y-6") do |form| %>
  <% if setting.errors.any? %>
    <div class="rounded-md bg-red-50 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800"><%= pluralize(setting.errors.count, "error") %> prohibited this setting from being saved:</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% setting.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :value, t('value'), class: form_label_class %>
    <div class="mt-1">
      <%= form.text_field :value, id: :setting_value, class: form_control_class, placeholder: t('placeholder_setting_value') %>
    </div>
    <p class="mt-2 text-sm text-gray-500"><%= t('placeholder_setting_value_help') %></p>
  </div>

  <div>
    <%= form.label :description, t('description'), class: form_label_class %>
    <div class="mt-1">
      <%= form.text_area :description, id: :setting_description, rows: 4, class: form_control_class, placeholder: t('placeholder_setting_description') %>
    </div>
    <p class="mt-2 text-sm text-gray-500"><%= t('placeholder_setting_description_help') %></p>
  </div>

  <div class="pt-5">
    <div class="flex justify-end">
      <%= form.submit t("ok"), class: "inline-flex justify-center rounded-lg border border-transparent bg-indigo-600 py-2.5 px-5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer" %>
    </div>
  </div>

<% end %>
