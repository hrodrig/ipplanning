<%= render layout: "common/admin_resource_form", locals: {
  heading: "#{t('infrastructure')}: #{@infrastructure.name}",
  index_path: infrastructures_path,
  index_label: t("infrastructures"),
  current_label: @infrastructure.name,
  back_path: infrastructures_path,
  primary_action_path: edit_infrastructure_path(@infrastructure),
  width_class: "max-w-6xl",
  form_card: false
} do %>
  <div class="mb-10 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4">
      <h2 class="text-base font-semibold text-gray-900"><%= t("details") %></h2>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("infrastructure_name") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @infrastructure.name %></dd>
      </div>
      <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
        <dt class="text-sm font-medium text-gray-700"><%= t("infrastructure_description") %></dt>
        <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @infrastructure.description %></dd>
      </div>
    </dl>
  </div>

  <h2 class="mb-4 text-lg font-bold tracking-tight text-gray-900"><%= t("infrastructure_hosts") %></h2>

  <% if @infrastructure.hosts.present? %>
    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gradient-to-b from-gray-50 to-gray-100/80">
            <tr>
              <th scope="col" class="px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600">#</th>
              <th scope="col" class="px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("hostname") %></th>
              <th scope="col" class="px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("host_type") %></th>
              <th scope="col" class="px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("environment") %></th>
              <th scope="col" class="px-5 py-3.5 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("description") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% @infrastructure.hosts.each_with_index do |host, index| %>
              <tr class="transition-colors hover:bg-gray-50/90">
                <td class="whitespace-nowrap px-5 py-4 text-center text-sm text-gray-500"><%= index + 1 %></td>
                <td class="whitespace-nowrap px-5 py-4 text-center text-sm font-medium">
                  <%= link_to host.name, host, class: "text-indigo-600 hover:text-indigo-500" %>
                </td>
                <td class="whitespace-nowrap px-5 py-4 text-center text-sm text-gray-800"><%= host.host_type&.name %></td>
                <td class="whitespace-nowrap px-5 py-4 text-center text-sm text-gray-800"><%= host.environment&.name %></td>
                <td class="px-5 py-4 text-center text-sm text-gray-700"><%= host.description.html_safe %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="rounded-lg border border-amber-100 bg-amber-50 px-4 py-3 text-sm text-amber-900 shadow-sm" role="status">
      <%= t("not_found_hosts") %>
    </div>
  <% end %>

  <div class="mt-10">
    <%= link_to t("add_infrastructure"), new_infrastructure_path, class: "inline-flex items-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-indigo-700 shadow-sm ring-1 ring-inset ring-indigo-200 hover:bg-indigo-50" %>
  </div>
<% end %>
