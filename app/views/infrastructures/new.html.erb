<%= render '/common/header' %>
<h1 class="h2"><%= t('add_infrastructure') %></h1>
<% if notice.present? %>
  <div class="mb-6 rounded-md bg-blue-50 p-4">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3"><p class="text-sm text-blue-700"><%= notice %></p></div>
    </div>
  </div>
<% end %>

<%= render 'form', infrastructure: @infrastructure %>

<%= link_to t('back'), :back, class: 'btn btn-default' %>
<%= link_to t('vlans'), :vlans, class: 'btn btn-link' %>
<%= link_to t('ips'), :ips, class: 'btn btn-link' %>
<%= link_to t('external_ips'), :externalips, class: 'btn btn-link' %>
<%= link_to t('hosts'), :hosts, class: 'btn btn-link' %>
<%= link_to t('infrastructures'), :infrastructures, class: 'btn btn-link' %>
<%= link_to t('environments'), :environments, class: 'btn btn-link' %>
<%= link_to t('host_types'), :host_types, class: 'btn btn-link' %>
