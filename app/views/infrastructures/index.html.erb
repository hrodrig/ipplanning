<%= render "/common/header" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-0 pb-10">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-gray-900"><%= t("infrastructures") %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= t("admin_crud_list_subtitle", count: @infrastructures.count) %></p>
    </div>
    <%= link_to t("add_infrastructure"), new_infrastructure_path, class: "inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
  </div>

  <%= render "common/admin_flash" %>

  <% if @infrastructures.present? %>
    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gradient-to-b from-gray-50 to-gray-100/80">
            <tr>
              <th scope="col" class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-600">#</th>
              <th scope="col" class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("name") %></th>
              <th scope="col" class="px-5 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("description") %></th>
              <th scope="col" class="relative px-5 py-3.5 text-right text-xs font-semibold uppercase tracking-wider text-gray-600">
                <span class="sr-only"><%= t("edit") %></span>
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            <% @infrastructures.each_with_index do |infrastructure, i| %>
              <tr class="transition-colors hover:bg-gray-50/90">
                <td class="whitespace-nowrap px-5 py-4 text-sm font-mono text-gray-500"><%= (i + 1).to_s %></td>
                <td class="whitespace-nowrap px-5 py-4 text-sm font-medium text-gray-900">
                  <%= link_to infrastructure.name, infrastructure, class: "text-indigo-600 hover:text-indigo-500" %>
                </td>
                <td class="max-w-md px-5 py-4 text-sm text-gray-600 truncate" title="<%= infrastructure.description %>"><%= infrastructure.description %></td>
                <td class="whitespace-nowrap px-5 py-4 text-right text-sm">
                  <%= link_to t("edit"), edit_infrastructure_path(infrastructure), class: "font-medium text-indigo-600 hover:text-indigo-500" %>
                  <span class="mx-2 text-gray-300" aria-hidden="true">|</span>
                  <%= link_to t("destroy"), infrastructure, data: { turbo_method: :delete, turbo_confirm: t("are_you_sure") }, class: "font-medium text-red-600 hover:text-red-500" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="rounded-lg border border-amber-100 bg-amber-50 px-4 py-3 text-sm text-amber-900 shadow-sm" role="status">
      <%= t("not_found_infrastructures") %>
    </div>
  <% end %>
</div>
