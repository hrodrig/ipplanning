<%= render layout: "common/admin_resource_form", locals: {
  heading: "#{t('host')}: #{@host.name}",
  index_path: hosts_path,
  index_label: t("hosts"),
  current_label: @host.name,
  back_path: hosts_path,
  primary_action_path: edit_host_path(@host),
  width_class: "max-w-6xl",
  form_card: false
} do %>
  <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
    <div class="space-y-8 lg:col-span-2">
      <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
        <div class="border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4">
          <h2 class="text-base font-semibold text-gray-900"><%= t("details") %></h2>
        </div>
        <dl class="divide-y divide-gray-100">
          <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
            <dt class="text-sm font-medium text-gray-700"><%= t("name") %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @host.name %></dd>
          </div>
          <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
            <dt class="text-sm font-medium text-gray-700"><%= t("description") %></dt>
            <dd class="mt-1 text-sm leading-relaxed text-gray-900 sm:col-span-2 sm:mt-0"><%= @host.description.html_safe %></dd>
          </div>
          <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
            <dt class="text-sm font-medium text-gray-700"><%= t("host_deployment_form") %></dt>
            <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @host.deployment_form_label %></dd>
          </div>
          <% if @host.rack_mount? && @host.server_rack.present? %>
            <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
              <dt class="text-sm font-medium text-gray-700"><%= t("host_server_rack") %></dt>
              <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
                <%= link_to "#{@host.server_rack.name} (#{@host.server_rack.location.name})", server_rack_path(@host.server_rack, highlight_host_id: @host.id), class: "text-indigo-600 hover:text-indigo-500" %>
              </dd>
            </div>
            <div class="px-5 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
              <dt class="text-sm font-medium text-gray-700"><%= t("host_rack_units") %> / <%= t("host_rack_position_start") %></dt>
              <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
                <%= @host.rack_units %>
                <% if @host.rack_position_start.present? %>
                  <span class="text-gray-500"> · U<%= @host.rack_position_start %>+</span>
                <% end %>
              </dd>
            </div>
          <% end %>
        </dl>
      </div>

      <% if @host.rack_mount? && @host.server_rack.present? %>
        <%= render "server_racks/u_diagram", server_rack: @host.server_rack, highlight_host: @host %>
      <% end %>

      <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
        <div class="border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4">
          <h2 class="text-base font-semibold text-gray-900"><%= t("specifications") %></h2>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("infrastructure") %></th>
                <th class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("environment") %></th>
                <th class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("host_type") %></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 bg-white">
              <tr>
                <td class="px-5 py-3 text-center text-gray-900"><%= @host.infrastructure&.name %></td>
                <td class="px-5 py-3 text-center text-gray-900"><%= @host.environment&.name %></td>
                <td class="px-5 py-3 text-center text-gray-900"><%= @host.host_type&.name %></td>
              </tr>
            </tbody>
            <thead class="bg-gray-50">
              <tr>
                <th class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("memory_size") %></th>
                <th class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("sockets") %></th>
                <th class="px-5 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"><%= t("cores") %></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 bg-white">
              <tr>
                <td class="px-5 py-3 text-center text-gray-900"><%= @host.memory_size %></td>
                <td class="px-5 py-3 text-center text-gray-900"><%= @host.total_sockets %></td>
                <td class="px-5 py-3 text-center text-gray-900"><%= @host.total_vcpus %></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-3 border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4">
          <h2 class="text-base font-semibold text-gray-900"><%= t("host_ports_section") %></h2>
          <div class="flex flex-wrap items-center gap-2">
            <%= link_to t("add_host_port"), new_host_host_port_path(@host), class: "inline-flex items-center rounded-lg bg-white px-3 py-1.5 text-sm font-semibold text-indigo-700 shadow-sm ring-1 ring-inset ring-indigo-200 hover:bg-indigo-50" %>
            <% if @host_ports.any? %>
              <%= link_to t("add_patch_connection"), new_host_patch_connection_path(@host), class: "inline-flex items-center rounded-lg bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
            <% end %>
          </div>
        </div>
        <div class="p-5">
          <% if @host_ports.any? %>
            <ul class="divide-y divide-gray-100">
              <% @host_ports.each do |port| %>
                <li class="flex flex-col gap-2 py-4 text-sm sm:flex-row sm:flex-wrap sm:items-center sm:justify-between">
                  <div>
                    <span class="font-mono font-medium text-gray-900"><%= port.name %></span>
                    <span class="ml-2 text-gray-600"><%= port.port_kind_label %></span>
                    <% if port.mac_address.present? %>
                      <span class="mt-1 block font-mono text-xs text-gray-500 sm:mt-0 sm:ml-2 sm:inline"><%= port.mac_address %></span>
                    <% end %>
                    <% if port.patch_connection.present? %>
                      <p class="mt-1 text-gray-700">
                        <span class="text-gray-500"><%= t("patch_to_switch") %>:</span>
                        <%= link_to port.patch_connection.switch_end_label, network_switch_path(port.patch_connection.switch_port.network_switch), class: "font-medium text-indigo-600 hover:text-indigo-500" %>
                      </p>
                    <% else %>
                      <p class="mt-1 text-xs text-amber-700"><%= t("host_port_no_patch") %></p>
                    <% end %>
                    <% if port.notes.present? %>
                      <p class="mt-1 text-xs text-gray-600"><%= port.notes %></p>
                    <% end %>
                  </div>
                  <span class="flex shrink-0 flex-wrap items-center gap-2">
                    <% if port.patch_connection.present? %>
                      <%= link_to t("edit_patch"), edit_host_patch_connection_path(@host, port.patch_connection), class: "font-medium text-indigo-600 hover:text-indigo-500" %>
                      <%= link_to t("remove_patch"), host_patch_connection_path(@host, port.patch_connection), data: { turbo_method: :delete, turbo_confirm: t("are_you_sure") }, class: "font-medium text-red-600 hover:text-red-500" %>
                    <% else %>
                      <%= link_to t("connect_patch"), new_host_patch_connection_path(@host, host_port_id: port.id), class: "font-medium text-indigo-600 hover:text-indigo-500" %>
                    <% end %>
                    <%= link_to t("edit"), edit_host_host_port_path(@host, port), class: "font-medium text-gray-600 hover:text-gray-500" %>
                    <%= link_to t("destroy"), host_host_port_path(@host, port), data: { turbo_method: :delete, turbo_confirm: t("are_you_sure") }, class: "font-medium text-red-600 hover:text-red-500" %>
                  </span>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-sm text-gray-500"><%= t("host_ports_empty_hint") %></p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <div class="flex items-center justify-between border-b border-gray-100 bg-gradient-to-b from-gray-50 to-gray-100/80 px-5 py-4">
        <h2 class="text-base font-semibold text-gray-900"><%= t("ips") %></h2>
        <%= link_to t("add_ip"), add_ip_to_host_path(@host), class: "inline-flex items-center rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-indigo-500" %>
      </div>
      <div class="p-5">
        <% if @host.ips.count > 0 %>
          <ul class="space-y-2">
            <% @host.ips.each do |ip| %>
              <li class="flex items-center justify-between rounded-lg border border-gray-100 bg-gray-50 px-3 py-2">
                <span class="font-mono text-sm text-gray-800"><%= ip.address %></span>
                <%= link_to t("destroy"), destroy_ip_from_host_path(@host, ip), data: { turbo_method: :delete, turbo_confirm: t("are_you_sure") }, class: "text-xs font-medium text-red-600 hover:text-red-500" %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="py-4 text-center text-sm text-gray-500"><%= t("not_found_ips") %></p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-10 flex flex-wrap gap-3">
    <%= link_to t("add_host"), new_host_path, class: "inline-flex items-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-indigo-700 shadow-sm ring-1 ring-inset ring-indigo-200 hover:bg-indigo-50" %>
  </div>
<% end %>
