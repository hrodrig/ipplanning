<%= form_with(model: host, local: true, class: "space-y-8") do |form| %>
  <% if host.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(host.errors.count, "error") %> <%= t('prohibited_this_information_from_being_saved') %>:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% host.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <div class="space-y-6">
      <div>
        <%= form.label :name, t('name'), class: form_label_class %>
        <div class="mt-1">
          <%= form.text_field :name, id: :host_name, class: form_control_class, placeholder: t('placeholder_hosts_hostname') %>
        </div>
      </div>

      <div>
        <%= form.label :description, t('description'), class: form_label_class %>
        <div class="mt-1">
          <%= form.text_area :description, id: :host_description, rows: 4, class: form_control_class, placeholder: t('placeholder_hosts_description') %>
        </div>
      </div>
    </div>

    <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
      <h3 class="text-lg font-medium text-gray-900 mb-4"><%= t('ips') %></h3>
      <% if action_name == 'edit' %>
        <% if host.ips.count > 0 %>
          <ul class="space-y-2 mb-4">
            <% host.ips.each do |ip| %>
              <li class="flex items-center justify-between bg-white p-2 rounded shadow-sm border border-gray-100">
                <span class="text-sm font-mono text-gray-700"><%= ip.address %></span>
                <%= link_to t('destroy'), destroy_ip_from_host_path(host, ip), data: { turbo_method: :delete }, class: "text-red-600 hover:text-red-800 text-xs font-semibold" %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-gray-500 mb-4"><%= t('not_found_ips') %></p>
        <% end %>
        <%= link_to t('add_ip'), add_ip_to_host_path(@host), class: 'inline-flex items-center px-4 py-2 bg-red-600 border border-transparent rounded-md font-semibold text-xs text-white uppercase tracking-widest hover:bg-red-700 focus:bg-red-700 active:bg-red-900 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition ease-in-out duration-150' %>
      <% else %>
        <div class="bg-blue-50 border-l-4 border-blue-400 p-4 text-sm text-blue-700">
          <%= t('create_host_to_add_ip') %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-6 border-t border-gray-200">
    <div>
      <%= form.label :infrastructure_id, t('infrastructure'), class: form_label_class %>
      <div class="mt-1">
        <%= form.select :infrastructure_id, Infrastructure.order(:name).collect{|row| [row.name, row.id]}, {}, { class: form_select_class } %>
      </div>
    </div>

    <div>
      <%= form.label :environment_id, t('environment'), class: form_label_class %>
      <div class="mt-1">
        <%= form.select :environment_id, Environment.order(:name).collect{|row| [row.name, row.id]}, {}, { class: form_select_class } %>
      </div>
    </div>

    <div>
      <%= form.label :host_type_id, t('host_type'), class: form_label_class %>
      <div class="mt-1">
        <%= form.select :host_type_id, HostType.order(:name).collect{|row| [row.name, row.id]}, {}, { class: form_select_class } %>
      </div>
    </div>
  </div>

  <div class="space-y-6 pt-6 border-t border-gray-200" data-controller="host-deployment">
    <div>
      <%= form.label :deployment_form, t("host_deployment_form"), class: form_label_class %>
      <div class="mt-1">
        <%= form.select :deployment_form,
          Host.deployment_form_select_options,
          {},
          {
            id: "host_deployment_form",
            class: form_select_class,
            data: { action: "change->host-deployment#sync" }
          } %>
      </div>
      <p class="mt-1 text-xs text-gray-500"><%= t("placeholder_host_deployment_form_help") %></p>
    </div>

    <div data-host-deployment-target="rackSection" class="space-y-6 rounded-lg border border-gray-200 bg-gray-50 p-6 <%= "hidden" unless host.rack_mount? %>">
      <p class="text-sm text-gray-600"><%= t("host_rack_mount_section_hint") %></p>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        <div class="md:col-span-2">
          <%= form.label :server_rack_id, t("host_server_rack"), class: form_label_class %>
          <div class="mt-1">
            <%= form.select :server_rack_id,
              ServerRack.left_joins(:location).order("locations.name ASC", "server_racks.name ASC").map { |sr|
                ["#{sr.name} — #{sr.location.name}", sr.id]
              },
              { include_blank: true },
              { class: form_select_class } %>
          </div>
        </div>
        <div>
          <%= form.label :rack_units, t("host_rack_units"), class: form_label_class %>
          <div class="mt-1">
            <%= form.number_field :rack_units, min: 1, class: form_control_class, placeholder: t("placeholder_host_rack_units") %>
          </div>
          <p class="mt-1 text-xs text-gray-500"><%= t("placeholder_host_rack_units_help") %></p>
        </div>
        <div>
          <%= form.label :rack_position_start, t("host_rack_position_start"), class: form_label_class %>
          <div class="mt-1">
            <%= form.number_field :rack_position_start, min: 1, class: form_control_class, placeholder: t("placeholder_host_rack_position_start") %>
          </div>
          <p class="mt-1 text-xs text-gray-500"><%= t("placeholder_host_rack_position_start_help") %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-6 border-t border-gray-200">
    <div>
      <%= form.label :memory_size, t('memory_size'), class: form_label_class %>
      <div class="mt-1">
        <%= form.text_field :memory_size, id: :memory_size, class: form_control_class, placeholder: t('placeholder_hosts_memory_size') %>
      </div>
    </div>

    <div>
      <%= form.label :total_sockets, t('sockets'), class: form_label_class %>
      <div class="mt-1">
        <%= form.text_field :total_sockets, id: :total_sockets, class: form_control_class, placeholder: t('placeholder_hosts_total_sockets') %>
      </div>
    </div>

    <div>
      <%= form.label :total_vcpus, t('cores'), class: form_label_class %>
      <div class="mt-1">
        <%= form.text_field :total_vcpus, id: :total_vcpus, class: form_control_class, placeholder: t('placeholder_hosts_total_vcpus') %>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end mt-8 pt-6 border-t border-gray-200">
    <%= form.submit t("ok"), class: "inline-flex items-center rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
  </div>
<% end %>
