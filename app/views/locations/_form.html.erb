<%= form_with(model: location, local: true, class: "space-y-6") do |form| %>
  <% if location.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(location.errors.count, "error") %> <%= t("prohibited_this_information_from_being_saved") %>:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% location.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :name, t("location_name"), class: form_label_class %>
    <div class="mt-1">
      <%= form.text_field :name, id: :location_name, class: form_control_class, placeholder: t("placeholder_location_name") %>
    </div>
    <p class="mt-2 text-sm text-gray-500"><%= t("placeholder_location_name_help") %></p>
  </div>

  <div>
    <%= form.label :description, t("description"), class: form_label_class %>
    <div class="mt-1">
      <%= form.text_area :description, id: :location_description, rows: 3, class: form_control_class, placeholder: t("placeholder_location_description") %>
    </div>
    <p class="mt-2 text-sm text-gray-500"><%= t("placeholder_location_description_help") %></p>
  </div>

  <div class="flex items-center justify-end mt-4">
    <%= form.submit t("ok"), class: "inline-flex items-center rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
  </div>
<% end %>
