<!DOCTYPE html>
<html class="h-full bg-gray-100 dark:bg-gray-950" lang="<%= I18n.locale %>">
  <head>
    <title>
      <% if @page_title.present? %>
        <%= @page_title %>
      <% else %>
        <%= Setting.find_by_name('WebsiteName')&.value || "IP Planning" %>
      <% end %>
    </title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <script>
      (function () {
        try {
          var k = "ipplanning-theme";
          var v = localStorage.getItem(k);
          var root = document.documentElement;
          if (v === "dark") root.classList.add("dark");
          else if (v === "light") root.classList.remove("dark");
          else if (window.matchMedia("(prefers-color-scheme: dark)").matches) root.classList.add("dark");
        } catch (e) {}
      })();
    </script>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full text-gray-900 dark:text-gray-100">
    <div
      class="flex min-h-full flex-col"
      data-controller="navbar theme"
      data-theme-dark-label-value="<%= t('theme_use_dark') %>"
      data-theme-light-label-value="<%= t('theme_use_light') %>"
    >
      <nav class="sticky top-0 z-50 border-b border-gray-700 bg-gray-800 shadow-sm">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex h-16 items-center justify-between">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <% brand_label = Setting.find_by_name("Brand")&.value.presence || "IPPLANNING" %>
                <% brand_mark_url = Setting.find_by_name("BrandMark")&.value.to_s.strip %>
                <a href="<%= root_path %>" class="group flex items-center gap-2.5 rounded-md text-xl font-bold text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-white/60">
                  <% if brand_mark_url.present? %>
                    <%= image_tag brand_mark_url, alt: "", class: "h-8 w-auto max-h-8 max-w-[2.75rem] object-contain" %>
                  <% else %>
                    <%= image_tag "brand-mark.svg", alt: "", class: "h-8 w-8 shrink-0 object-contain opacity-90 transition-opacity group-hover:opacity-100" %>
                  <% end %>
                  <span class="truncate tracking-tight"><%= brand_label %></span>
                </a>
              </div>
              <div class="hidden md:block">
                <div class="ml-10 flex items-baseline space-x-4">
                  <% if admin_signed_in? %>
                    <a href="/" class="<%= controller_name == 'welcome' ? 'bg-gray-900 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white' %> px-3 py-2 rounded-md text-sm font-medium"><%= t('home') %></a>
                    <a href="/vlans" class="<%= controller_name == 'vlans' ? 'bg-gray-900 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white' %> px-3 py-2 rounded-md text-sm font-medium"><%= t('vlans') %></a>
                    <a href="/ips" class="<%= controller_name == 'ips' ? 'bg-gray-900 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white' %> px-3 py-2 rounded-md text-sm font-medium"><%= t('ips') %></a>
                    <a href="/externalips" class="<%= controller_name == 'externalips' ? 'bg-gray-900 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white' %> px-3 py-2 rounded-md text-sm font-medium"><%= t('external_ips') %></a>
                    <a href="/hosts" class="<%= controller_name == 'hosts' ? 'bg-gray-900 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white' %> px-3 py-2 rounded-md text-sm font-medium"><%= t('hosts') %></a>
                    
                    <div class="relative">
                      <button data-action="click->navbar#toggleDropdown" class="text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium flex items-center">
                        <%= t('platform_settings') %>
                        <svg class="ml-1 h-4 w-4 fill-current" viewBox="0 0 20 20"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg>
                      </button>
                      <div data-navbar-target="dropdown" class="hidden absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-md bg-white py-1 shadow-lg ring-1 ring-black/5 focus:outline-none dark:bg-gray-900 dark:ring-white/10">
                        <a href="/infrastructures" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800"><%= t('infrastructures') %></a>
                        <a href="/locations" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800"><%= t('locations') %></a>
                        <a href="/server_racks" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800"><%= t('server_racks') %></a>
                        <a href="/network_switches" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800"><%= t('network_switches') %></a>
                        <a href="/environments" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800"><%= t('environments') %></a>
                        <a href="/host_types" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800"><%= t('host_types') %></a>
                        <div class="border-t border-gray-100 dark:border-gray-700"></div>
                        <a href="/settings" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800"><%= t('settings') %></a>
                      </div>
                    </div>
                    <a href="/etc/hosts" class="<%= controller_name == 'etchosts' ? 'bg-gray-900 text-white' : 'text-gray-300 hover:bg-gray-700 hover:text-white' %> px-3 py-2 rounded-md text-sm font-medium">/etc/hosts</a>
                  <% end %>
                </div>
              </div>
            </div>
              <div class="hidden md:block">
                <div class="ml-4 flex items-center md:ml-6 space-x-2">
                  <div class="flex bg-gray-700 rounded-md p-1">
                    <%= link_to "EN", { locale: :en }, class: "px-2 py-1 text-xs font-medium rounded-md #{I18n.locale == :en ? 'bg-gray-900 text-white' : 'text-gray-300 hover:text-white'}" %>
                    <%= link_to "ES", { locale: :es }, class: "px-2 py-1 text-xs font-medium rounded-md #{I18n.locale == :es ? 'bg-gray-900 text-white' : 'text-gray-300 hover:text-white'}" %>
                  </div>
                  <button
                    type="button"
                    data-action="click->theme#toggle"
                    data-theme-target="control"
                    class="rounded-md p-2 text-gray-300 hover:bg-gray-700 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-white/60"
                  >
                    <span data-theme-target="moon" class="block">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
                    </span>
                    <span data-theme-target="sun" class="hidden">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
                    </span>
                  </button>
                  <% if admin_signed_in? %>
                    <%= link_to t('destroy_session'), destroy_admin_session_path, data: { turbo_method: :delete }, class: "text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
                  <% else %>
                    <%= link_to t('new_sesion'), new_admin_session_path, class: "text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
                  <% end %>
                </div>
              </div>
            <div class="-mr-2 flex md:hidden">
              <button data-action="click->navbar#toggleMenu" type="button" class="inline-flex items-center justify-center rounded-md bg-gray-800 p-2 text-gray-400 hover:bg-gray-700 hover:text-white focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-800">
                <span class="sr-only">Open main menu</span>
                <svg class="block h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Mobile menu -->
        <div data-navbar-target="menu" class="hidden md:hidden">
          <div class="space-y-1 px-2 pb-3 pt-2 sm:px-3">
            <% if admin_signed_in? %>
              <a href="/" class="text-gray-300 hover:bg-gray-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium"><%= t('home') %></a>
              <a href="/vlans" class="text-gray-300 hover:bg-gray-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium"><%= t('vlans') %></a>
              <a href="/ips" class="text-gray-300 hover:bg-gray-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium"><%= t('ips') %></a>
              <a href="/externalips" class="text-gray-300 hover:bg-gray-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium"><%= t('external_ips') %></a>
              <a href="/hosts" class="text-gray-300 hover:bg-gray-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium"><%= t('hosts') %></a>
              <a href="/etc/hosts" class="text-gray-300 hover:bg-gray-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium">/etc/hosts</a>
            <% end %>
          </div>
          <div class="border-t border-gray-700 pb-3 pt-4">
            <div class="px-2 mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:space-x-4">
              <div class="flex items-center space-x-4">
                <span class="text-gray-400 text-xs font-semibold uppercase tracking-wider px-3">Language</span>
                <div class="flex rounded-md bg-gray-700 p-1">
                  <%= link_to "EN", { locale: :en }, class: "px-3 py-1 text-sm font-medium rounded-md #{I18n.locale == :en ? 'bg-gray-900 text-white' : 'text-gray-300 hover:text-white'}" %>
                  <%= link_to "ES", { locale: :es }, class: "px-3 py-1 text-sm font-medium rounded-md #{I18n.locale == :es ? 'bg-gray-900 text-white' : 'text-gray-300 hover:text-white'}" %>
                </div>
              </div>
              <div class="flex items-center space-x-3 px-3">
                <span class="text-gray-400 text-xs font-semibold uppercase tracking-wider"><%= t("theme_menu_label") %></span>
                <button
                  type="button"
                  data-action="click->theme#toggle"
                  data-theme-target="control"
                  class="inline-flex items-center rounded-md bg-gray-700 p-2 text-gray-200 hover:bg-gray-600 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50"
                >
                  <span data-theme-target="moon" class="block">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
                  </span>
                  <span data-theme-target="sun" class="hidden">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
                  </span>
                </button>
              </div>
            </div>
            <div class="px-2">
              <% if admin_signed_in? %>
                <%= link_to t('destroy_session'), destroy_admin_session_path, data: { turbo_method: :delete }, class: "text-gray-300 hover:bg-gray-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium" %>
              <% else %>
                <%= link_to t('new_sesion'), new_admin_session_path, class: "text-gray-300 hover:bg-gray-700 hover:text-white block px-3 py-2 rounded-md text-base font-medium" %>
              <% end %>
            </div>
          </div>
        </div>
      </nav>

      <main class="flex-1 bg-gray-100 dark:bg-gray-950">
        <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
          <%= yield %>
        </div>
      </main>

      <footer class="mt-auto border-t border-gray-200 bg-white py-4 dark:border-gray-800 dark:bg-gray-900">
        <div class="mx-auto max-w-7xl px-4 text-center text-sm text-gray-500 dark:text-gray-400 sm:px-6 lg:px-8">
          <%= Setting.find_by_name('Footer')&.value&.html_safe || "&copy; 2024 IPPLANNING".html_safe %>
        </div>
      </footer>
    </div>
  </body>
</html>
